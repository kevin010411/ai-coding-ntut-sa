{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "review-result.schema.json",
  "title": "Multi-Model Review Result",
  "description": "Standardized schema for LLM code review outputs, enabling cross-model aggregation",
  "type": "object",
  "required": ["reviewer", "timestamp", "target", "findings", "summary"],
  "properties": {
    "reviewer": {
      "type": "object",
      "description": "Information about the reviewing model",
      "required": ["model"],
      "properties": {
        "model": {
          "type": "string",
          "enum": ["claude", "gemini", "chatgpt", "codex"],
          "description": "The LLM that performed this review"
        },
        "version": {
          "type": "string",
          "description": "Model version (e.g., 'gpt-4o', 'gemini-1.5-pro')"
        },
        "prompt_version": {
          "type": "string",
          "description": "Version of the review prompt used"
        }
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the review was performed"
    },
    "target": {
      "type": "object",
      "description": "What was reviewed",
      "required": ["type", "spec_files", "impl_files"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["spec-compliance", "code-review", "security-review"],
          "description": "Type of review performed"
        },
        "spec_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of specification files reviewed"
        },
        "impl_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of implementation files reviewed"
        },
        "problem_frame": {
          "type": "string",
          "description": "Path to the spec directory (if applicable)"
        }
      }
    },
    "findings": {
      "type": "array",
      "description": "List of issues found during review",
      "items": {
        "type": "object",
        "required": ["id", "severity", "category", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^F[0-9]{3}$",
            "description": "Unique finding ID (e.g., F001, F002)"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "Issue severity level"
          },
          "category": {
            "type": "string",
            "enum": [
              "missing-attribute",
              "type-mismatch",
              "missing-precondition",
              "missing-postcondition",
              "missing-invariant",
              "missing-test",
              "missing-assertion",
              "logic-error",
              "naming-mismatch",
              "contract-violation",
              "event-schema-mismatch",
              "other"
            ],
            "description": "Category of the finding"
          },
          "spec_reference": {
            "type": "string",
            "description": "Reference to spec location (e.g., 'aggregate.yaml:173')"
          },
          "impl_reference": {
            "type": "string",
            "description": "Reference to implementation location (e.g., 'Workflow.java:45')"
          },
          "description": {
            "type": "string",
            "description": "Clear description of the issue"
          },
          "expected": {
            "type": "string",
            "description": "What the spec requires"
          },
          "actual": {
            "type": "string",
            "description": "What the implementation does"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Model's confidence in this finding (0.0-1.0)"
          },
          "suggested_fix": {
            "type": "string",
            "description": "Optional suggested fix"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "description": "Summary statistics",
      "required": ["compliance_rate", "verdict"],
      "properties": {
        "compliance_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Overall compliance rate (0.0-1.0)"
        },
        "total_findings": {
          "type": "integer",
          "minimum": 0
        },
        "critical_count": {
          "type": "integer",
          "minimum": 0
        },
        "high_count": {
          "type": "integer",
          "minimum": 0
        },
        "medium_count": {
          "type": "integer",
          "minimum": 0
        },
        "low_count": {
          "type": "integer",
          "minimum": 0
        },
        "verdict": {
          "type": "string",
          "enum": ["pass", "fail", "needs-review"],
          "description": "Overall verdict"
        },
        "notes": {
          "type": "string",
          "description": "Additional notes from the reviewer"
        }
      }
    }
  }
}
