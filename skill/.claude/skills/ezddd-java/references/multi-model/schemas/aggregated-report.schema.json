{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aggregated-report.schema.json",
  "title": "Aggregated Multi-Model Review Report",
  "description": "Schema for aggregated results from multiple LLM reviewers",
  "type": "object",
  "required": ["review_id", "timestamp", "models_used", "consensus_findings", "summary"],
  "properties": {
    "review_id": {
      "type": "string",
      "description": "Unique identifier for this review session"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the aggregation was performed"
    },
    "target": {
      "type": "object",
      "properties": {
        "problem_frame": { "type": "string" },
        "spec_files": { "type": "array", "items": { "type": "string" } },
        "impl_files": { "type": "array", "items": { "type": "string" } }
      }
    },
    "models_used": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "model": { "type": "string" },
          "version": { "type": "string" },
          "findings_count": { "type": "integer" },
          "verdict": { "type": "string" }
        }
      },
      "description": "List of models that participated in the review"
    },
    "consensus_findings": {
      "type": "array",
      "description": "Findings with consensus analysis",
      "items": {
        "type": "object",
        "required": ["finding_id", "consensus_score", "status", "agreed_by"],
        "properties": {
          "finding_id": {
            "type": "string",
            "description": "Normalized finding ID"
          },
          "consensus_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Percentage of models that found this issue"
          },
          "status": {
            "type": "string",
            "enum": ["confirmed", "likely", "disputed", "unique"],
            "description": "Consensus status based on agreement level"
          },
          "agreed_by": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of models that found this issue"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "category": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "description": "Merged description from agreeing models"
          },
          "spec_reference": {
            "type": "string"
          },
          "impl_reference": {
            "type": "string"
          },
          "arbitration": {
            "type": "object",
            "description": "Claude's arbitration for disputed findings",
            "properties": {
              "decision": {
                "type": "string",
                "enum": ["confirmed", "rejected", "modified"]
              },
              "rationale": {
                "type": "string"
              },
              "final_severity": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low", "false-positive"]
              }
            }
          }
        }
      }
    },
    "model_agreement_matrix": {
      "type": "object",
      "description": "Pairwise agreement rates between models",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "degradation": {
      "type": "object",
      "description": "Degradation status when fewer than 4 models responded",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["normal", "partial", "degraded", "single-model"],
          "description": "Operating mode based on responding model count"
        },
        "responded_models": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Models that successfully returned results"
        },
        "failed_models": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "model": { "type": "string" },
              "reason": {
                "type": "string",
                "enum": ["timeout", "unavailable", "invalid-json", "error"]
              }
            }
          },
          "description": "Models that failed with failure reasons"
        },
        "warning": {
          "type": "string",
          "description": "Human-readable warning about degraded operation"
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["final_compliance_rate", "final_verdict"],
      "properties": {
        "total_unique_findings": {
          "type": "integer"
        },
        "confirmed_findings": {
          "type": "integer",
          "description": "Findings with consensus_score >= 0.6"
        },
        "disputed_findings": {
          "type": "integer",
          "description": "Findings with consensus_score < 0.6"
        },
        "false_positives": {
          "type": "integer",
          "description": "Findings rejected by arbitration"
        },
        "model_verdicts": {
          "type": "object",
          "description": "Each model's individual verdict",
          "additionalProperties": {
            "type": "string",
            "enum": ["pass", "fail", "needs-review"]
          }
        },
        "final_compliance_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Weighted average compliance rate"
        },
        "final_verdict": {
          "type": "string",
          "enum": ["pass", "fail", "needs-review"],
          "description": "Final aggregated verdict"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence in the final verdict based on model agreement"
        },
        "effectiveness_metrics": {
          "type": "object",
          "description": "Optional metrics measuring multi-model review effectiveness",
          "properties": {
            "dedup_ratio": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "unique_findings / raw_findings — lower means more noise filtered"
            },
            "false_positive_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "false_positives / total_unique_findings"
            },
            "cost_per_confirmed_finding_usd": {
              "type": "number",
              "minimum": 0,
              "description": "total_external_cost / confirmed_findings"
            },
            "parallel_speedup_factor": {
              "type": "number",
              "minimum": 1,
              "description": "sequential_total / wall_clock_time"
            }
          }
        }
      }
    }
  }
}
