{
  "projectName": "AiScrum",
  "groupId": "tw.teddysoft.aiscrum",
  "artifactId": "tw.teddysoft.aiscrum",
  "version": "0.1.0-SNAPSHOT",
  "packaging": "jar",
  "rootPackage": "tw.teddysoft.aiscrum",
  "description": "使用 Claude 與 EZ-AI 開發 ezScrum 專案",
  "techStack": "ezddd-java",
  "javaVersion": "21",
  "springBootVersion": "3.5.3",
  "dependencies": {
    "ezappStarterVersion": "2.0.0",
    "junitVersion": "5.10.2",
    "junitPlatformVersion": "1.10.2",
    "mockitoVersion": "5.11.0",
    "orgJsonVersion": "20211205",
    "awaitilityVersion": "4.2.0",
    "byteBuddyVersion": "1.15.10"
  },
  "mavenPlugins": {
    "compilerPluginVersion": "3.10.1",
    "surefirePluginVersion": "3.1.2"
  },
  "database": {
    "environments": {
      "test": {
        "type": "PostgreSQL",
        "host": "localhost",
        "port": 5800,
        "name": "board",
        "username": "postgres",
        "password": "root",
        "url": "jdbc:postgresql://localhost:5800/board?currentSchema=message_store",
        "schema": "message_store",
        "jpa": {
          "ddlAuto": "update",
          "showSql": true
        },
        "containerName": "postgres_ezscrum_test"
      },
      "production": {
        "type": "PostgreSQL",
        "host": "localhost",
        "port": 5500,
        "name": "board",
        "username": "postgres",
        "password": "root",
        "url": "jdbc:postgresql://localhost:5500/board?currentSchema=message_store",
        "schema": "message_store",
        "jpa": {
          "ddlAuto": "update",
          "showSql": false
        },
        "containerName": "postgres_ezscrum_prod"
      },
      "ai": {
        "type": "PostgreSQL",
        "host": "localhost",
        "port": 6600,
        "name": "board_ai",
        "username": "postgres",
        "password": "root",
        "url": "jdbc:postgresql://localhost:6600/board?currentSchema=message_store",
        "schema": "message_store",
        "jpa": {
          "ddlAuto": "update",
          "showSql": true
        },
        "containerName": "postgres_ezscrum_ai"
      }
    },
    "driver": "org.postgresql.Driver",
    "dialect": "org.hibernate.dialect.PostgreSQLDialect"
  },
  "features": {
    "eventSourcing": true,
    "cqrs": true,
    "restApi": true,
    "swagger": false
  },
  "frontend": {
    "framework": "React",
    "language": "TypeScript",
    "port": 3000,
    "buildTool": "Vite",
    "dependencies": {
      "react": "18.3.1",
      "typescript": "5.5.3",
      "vite": "5.4.1"
    }
  },
  "backend": {
    "port": 9090,
    "contextPath": "/",
    "apiPrefix": "/v1/api"
  },
  "architecture": {
    "defaultPattern": "outbox",
    "profiles": {
      "inmemory": ["inmemory", "test-inmemory"],
      "outbox": ["outbox", "test-outbox"],
      "eventsourcing": ["eventsourcing", "test-eventsourcing"]
    },
    "aggregates": {
      "Product": {
        "pattern": "outbox",
        "eventStore": false
      },
      "Sprint": {
        "pattern": "outbox",
        "eventStore": false
      },
      "ProductBacklogItem": {
        "pattern": "outbox",
        "eventStore": false
      },
      "ScrumTeam": {
        "pattern": "outbox",
        "eventStore": false
      }
    },
    "commandDefaults": {
      "repository": "outbox",
      "generateOutboxPattern": true,
      "dualProfileSupport": true
    },
    "conventions": {
      "configPackage": "io.springboot.config",
      "namingPatterns": {
        "repositoryConfig": "{Profile}RepositoryConfig",
        "projectionConfig": "{Profile}ProjectionConfig",
        "infrastructureConfig": "{Profile}InfrastructureConfig",
        "archiveConfig": "{Profile}ArchiveConfig"
      }
    }
  }
}