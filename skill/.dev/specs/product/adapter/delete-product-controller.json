{
  "controller": "DeleteProductController",
  "useCase": "DeleteProductUseCase",
  "method": "DELETE",
  "path": "/v1/api/products/{productId}",
  "pathVariables": [
    { "name": "productId", "type": "String", "description": "Product ID to delete" }
  ],
  "requestHeaders": [
    { "name": "X-User-Id", "type": "String", "required": true, "description": "User ID performing the deletion" }
  ],
  "requestBody": null,
  "responseBody": {
    "202": {
      "description": "Product deletion accepted",
      "fields": [
        { "name": "id", "type": "String", "description": "Deleted product ID" },
        { "name": "message", "type": "String", "description": "Success message" }
      ]
    },
    "404": {
      "description": "Product not found",
      "fields": [
        { "name": "error", "type": "String", "description": "Error message" }
      ]
    },
    "400": {
      "description": "Bad request - missing user ID header",
      "fields": [
        { "name": "error", "type": "String", "description": "Error message" }
      ]
    }
  },
  "testing": {
    "unitTest": "DeleteProductControllerTest",
    "integrationTest": "DeleteProductControllerIntegrationTest",
    "scenarios": [
      "Successfully delete existing product",
      "Return 404 when product not found",
      "Return 400 when user ID header missing"
    ]
  }
}