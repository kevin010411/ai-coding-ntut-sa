{
  "useCase": "SetProductGoalController",
  "behavior": "Set or update the goal of a product (eventual consistency, async-202).",
  "spec": {
    "basePath": "/v1/api/products/{productId}/goal",
    "endpoints": [
      {
        "method": "POST",
        "path": "",
        "summary": "Set product goal",
        "useCase": "SetProductGoalUseCase",
        "mapping": {
          "input": {
            "type": "body",
            "dto": "SetProductGoalRequest"
          },
          "pathVars": ["productId"],
          "output": { "mode": "async-202", "operationId": true }
        },
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "security": { "auth": "jwt-required", "roles": ["PRODUCT_WRITE"] },
        "responses": {
          "202": { "body": "AcceptedResponse", "headers": ["Location","Operation-Id"] },
          "400": { "body": "ApiError" },
          "401": { "body": "ApiError" },
          "403": { "body": "ApiError" },
          "404": { "body": "ApiError" },
          "409": { "body": "ApiError" }
        },
        "headers": {
          "request": ["Idempotency-Key"],
          "response": ["Location","Operation-Id","traceId"]
        }
      }
    ],
    "errorMapping": [
      { "domain": "ProductNotFound", "http": 404, "code": "PRODUCT_NOT_FOUND" },
      { "domain": "InvalidGoalState", "http": 400, "code": "INVALID_GOAL_STATE" },
      { "domain": "ConcurrentModification", "http": 409, "code": "VERSION_CONFLICT" }
    ]
  },
  "contracts": {
    "dtos": [
      {
        "name": "SetProductGoalRequest",
        "fields": [
          {
            "name": "name",
            "type": "String",
            "required": true,
            "minLength": 1,
            "maxLength": 100
          },
          {
            "name": "description",
            "type": "String",
            "required": true,
            "minLength": 1,
            "maxLength": 512
          },
          {
            "name": "state",
            "type": "String",
            "required": true,
            "minLength": 1,
            "maxLength": 32
          }
        ]
      }
    ]
  },
  "policies": {
    "idempotency": { "header": "Idempotency-Key", "ttlSeconds": 600 },
    "observability": { "logging": "request-and-error", "tracing": true, "metrics":
    true }
  }
}