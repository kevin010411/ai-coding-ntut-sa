{
  "useCase": "DefineDefinitionOfDoneController",
  "behavior": "Define a Definition of Done (DoD) for a product.",
  "spec": {
    "basePath": "/v1/api/products/{productId}/dod",
    "endpoints": [
      {
        "method": "POST",
        "path": "",
        "summary": "Define DoD",
        "useCase": "DefineDefinitionOfDoneUseCase",
        "mapping": {
          "input": { "type": "body", "dto": "DefineDefinitionOfDoneRequest" },
          "pathVars": ["productId"],
          "output": { "mode": "async-202", "operationId": true }
        },
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "responses": {
          "202": { "body": "AcceptedResponse", "headers":
          ["Location","Operation-Id"] },
          "400": { "body": "ApiError" },
          "404": { "body": "ApiError" },
          "409": { "body": "ApiError" }
        }
      }
    ],
    "errorMapping": [
      { "domain": "ProductNotFound", "http": 404, "code": "PRODUCT_NOT_FOUND" },
      { "domain": "DuplicateDoDName", "http": 409, "code": "DOD_NAME_CONFLICT" },
      { "domain": "InvalidCriterion", "http": 400, "code": "INVALID_CRITERION" }
    ]
  },
  "contracts": {
    "dtos": [
      {
        "name": "DefineDefinitionOfDoneRequest",
        "fields": [
          {
            "name": "name",
            "type": "string",
            "required": true,
            "minLength": 1,
            "maxLength": 100
          },
          {
            "name": "criteria",
            "type": "List<string>",
            "required": true,
            "minItems": 1,
            "maxItems": 36,
            "itemConstraints": {
              "minLength": 1,
              "maxLength": 100,
              "pattern": "^[A-Za-z0-9 _-]+$"
            },
            "unique": true,
            "trim": true
          },
          {
            "name": "note",
            "type": "string",
            "required": false,
            "maxLength": 512
          }
        ]
      },
      {
        "name": "AcceptedResponse",
        "fields": [
          { "name": "operationId", "type": "string" },
          { "name": "status", "type": "string", "default": "ACCEPTED" }
        ]
      },
      {
        "name": "ApiError",
        "fields": [
          { "name": "code", "type": "string" },
          { "name": "message", "type": "string" },
          { "name": "traceId", "type": "string" }
        ]
      }
    ]
  },
  "policies": {
    "idempotency": {
      "header": "Idempotency-Key",
      "ttlSeconds": 600
    },
    "observability": {
      "logging": "request-and-error",
      "tracing": true
    }
  }
}