{
  "restController": "GetProductController",
  "spec": {
    "basePath": "v1/api/products/{productId}",
    "endpoints": [
      {
        "method": "GET",
        "path": "",
        "useCase": "GetProductUseCase",
        "mapping": {
          "input": {
            "type": "path",
            "pathVars": ["productId"]
          },
          "output": {
            "type": "dto",
            "dto": "ProductDto"
          }
        },
        "responses": {
          "200": { "body": "ProductDto" },
          "400": { "body": "ApiError" },
          "404": { "body": "ApiError" },
          "401": { "body": "ApiError" }
        },
        "produces": ["application/json"]
      }
    ]
  },
  "contracts": {
        "name": "ApiError",
        "fields": [
          { "name": "code", "type": "string", "example": "PRODUCT_NOT_FOUND" },
          { "name": "message", "type": "string" },
          { "name": "traceId", "type": "string" }
        ]
  },
  "policies": {
    "validation": [
      { "target": "path.productId", "rules": ["notBlank"] }
    ],
    "domainExposure": {
      "pattern": "read-only-entity",
      "rules": [
        "Controller may serialize ProductDto returned by GetProductUseCase.",
        "Controller must not map ProductDto back to ProductDto.",
        "Controller must not expose mutable Product entity."
      ]
    },
    "caching": { "etag": "optional", "cacheControl": "max-age=60, public" },
    "observability": { "logging": "request-and-error", "tracing": true, "metrics": true }
  }
}
