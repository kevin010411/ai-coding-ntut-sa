{
  "useCase": "RenameProductController",
  "behavior": "Rename a product (eventual consistency, async-202).",
  "spec": {
    "basePath": "/v1/api/products/{productId}/name",
    "endpoints": [
      {
        "method": "PUT",
        "path": "",
        "summary": "Rename product",
        "useCase": "RenameProductUseCase",
        "mapping": {
          "input": { "type": "body", "dto": "RenameProductRequest" },
          "pathVars": ["productId"],
          "output": { "mode": "async-202", "operationId": true }
        },
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "responses": {
          "202": { "body": "AcceptedResponse", "headers": ["Location", "Operation-Id"] },
          "400": { "body": "ApiError" },
          "404": { "body": "ApiError" },
          "409": { "body": "ApiError" }
        }
      }
    ],
    "errorMapping": [
      { "domain": "ProductNotFound", "http": 404, "code": "PRODUCT_NOT_FOUND" },
      { "domain": "InvalidProductName", "http": 400, "code": "INVALID_PRODUCT_NAME" },
      { "domain": "ConcurrentModification", "http": 409, "code": "VERSION_CONFLICT" }
    ]
  },
  "contracts": {
    "dtos": [
      {
        "name": "RenameProductRequest",
        "fields": [
          {
            "name": "name",
            "type": "string",
            "required": true,
            "minLength": 1,
            "maxLength": 100
          }
        ]
      },
      {
        "name": "AcceptedResponse",
        "fields": [
          { "name": "operationId", "type": "string" },
          { "name": "status", "type": "string", "default": "ACCEPTED" }
        ]
      },
      {
        "name": "ApiError",
        "fields": [
          { "name": "code", "type": "string" },
          { "name": "message", "type": "string" },
          { "name": "traceId", "type": "string" }
        ]
      }
    ]
  },
  "policies": {
    "idempotency": { "header": "Idempotency-Key", "ttlSeconds": 600 },
    "observability": { "logging": "request-and-error", "tracing": true }
  }
}
