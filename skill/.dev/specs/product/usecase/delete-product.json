{
  "useCase": "DeleteProduct",
  "behavior": "Delete a product",
  "input": [
    { "name": "productId", "type": "String", "note": "Product 的唯一識別碼" },
    { "name": "userId", "type": "String", "note": "刪除 Product 的使用者" }
  ],
  "aggregate": "Product",
  "aggregateId": "ProductId",
  "method": "Product.markAsDelete",
  "domainEvent": "ProductEvents.ProductDeleted",
  "repository": "ProductRepository",
  "output": "CqrsOutput with productId",
  "domainModelNotes": [
  ],
  "domainEvents": [
    {
      "name": "ProductEvents.ProductDeleted",
      "description": "產品被標注刪除",
      "attributes": [
        { "name": "productId", "type": "ProductId" },
        { "name": "userId", "type": "String" }
      ]
    }
  ]
}