{
  "useCase": "SetProductGoal",
  "behavior": "Set a product goal",
  "input": [
    { "name": "productId", "type": "String", "note": "Product 的唯一識別碼" },
    { "name": "productGoalId", "type": "String", "note": "Product goal 的唯一識別碼" },
    { "name": "name", "type": "String", "note": "Product goal 的顯示名稱" },
    { "name": "description", "type": "String", "note": "Product goal 詳細描述" },
    { "name": "state", "type": "String", "note": "{PLAN or ACTIVE}" }
  ],
  "aggregate": "Product",
  "aggregateId": "ProductId",
  "method": "Product.setGoal",
  "domainEvent": "ProductEvents.ProductGoalSet",
  "repository": "ProductRepository",
  "output": "CqrsOutput with productGoalId",
  "domainModelNotes": [
  ],
  "domainEvents": [
    {
      "name": "ProductEvents.ProductGoalSet",
      "description": "產品目標設立",
      "attributes": [
        { "name": "productId", "type": "ProductId" },
        { "name": "productGoalId", "type": "ProductGoalId" },
        { "name": "name", "type": "String" },
        { "name": "description", "type": "String" },
        { "name": "state", "type": "ProductGoalState"}
      ]
    }
  ],
  "entities": [
    {
      "name": "ProductGoal",
      "description": "產品目標",
      "attributes": [
        { "name": "id", "type": "ProductGoalId" },
        { "name": "title", "type": "String" },
        { "name": "description", "type": "String" },
        { "name": "metrics", "type": "final List<GoalMetric>" },
        { "name": "state", "type": "ProductGoalState" }
      ]
    }
  ]
}