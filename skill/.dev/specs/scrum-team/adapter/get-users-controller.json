{
  "useCase": "GetUsersController",
  "behavior": "Get all users in the system.",
  "spec": {
    "basePath": "/v1/api/users",
    "endpoints": [
      {
        "method": "GET",
        "path": "",
        "summary": "Get all users",
        "useCase": "GetUsersUseCase",
        "mapping": {
          "input": {
            "type": "none"
          },
          "output": {
            "mode": "sync-200",
            "type": "list",
            "entity": "UserReadOnly",
            "itemType": "readOnlyEntity"
          }
        },
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "body": "List<UserReadOnly>"
          },
          "401": {
            "body": "ApiError"
          },
          "403": {
            "body": "ApiError"
          },
          "500": {
            "body": "ApiError"
          }
        },
        "headers": {
          "request": [],
          "response": [
            "traceId"
          ]
        }
      }
    ],
    "errorMapping": [
      {
        "domain": "InternalError",
        "http": 500,
        "code": "INTERNAL_ERROR"
      }
    ]
  },
  "contracts": {
    "readOnlyEntities": [
      {
        "name": "UserReadOnly",
        "fields": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "email",
            "type": "string"
          }
        ]
      }
    ],
    "errors": [
      {
        "name": "ApiError",
        "fields": [
          {
            "name": "code",
            "type": "string"
          },
          {
            "name": "message",
            "type": "string"
          },
          {
            "name": "traceId",
            "type": "string"
          }
        ]
      }
    ]
  },
  "policies": {
    "caching": {
      "enabled": true,
      "ttlSeconds": 60
    },
    "observability": {
      "logging": "request-and-error",
      "tracing": true,
      "metrics": true
    },
    "domainExposure": {
      "pattern": "read-only-entity",
      "rules": [
        "Controller may serialize immutable List<UserReadOnly> returned by GetUsersUseCase.",
        "Controller must not map UserReadOnly back to UserDto.",
        "Controller must not expose mutable User entity or mutable collection."
      ]
    }
  }
}
