{
  "name": "GetScrumTeamsController",
  "type": "rest-controller",
  "description": "REST controller for retrieving all Scrum teams",
  "package": "tw.teddysoft.aiscrum.scrumteam.adapter.in.rest.springboot",
  "endpoint": {
    "method": "GET",
    "path": "/v1/api/scrum-teams",
    "description": "Get all Scrum teams"
  },
  "request": {
    "type": "none",
    "description": "No request body required for GET endpoint"
  },
  "response": {
    "name": "ScrumTeamsResponse",
    "fields": [
      {
        "name": "teams",
        "type": "List<ScrumTeamDto>",
        "description": "List of Scrum teams"
      },
      {
        "name": "totalCount",
        "type": "int",
        "description": "Total number of teams"
      }
    ],
    "dto": {
      "name": "ScrumTeamDto",
      "fields": [
        {
          "name": "teamId",
          "type": "String",
          "description": "Team unique identifier"
        },
        {
          "name": "name",
          "type": "String",
          "description": "Team name"
        },
        {
          "name": "description",
          "type": "String",
          "description": "Team description"
        },
        {
          "name": "memberCount",
          "type": "int",
          "description": "Number of team members"
        },
        {
          "name": "createdAt",
          "type": "String",
          "description": "Team creation timestamp"
        }
      ]
    }
  },
  "errorResponse": {
    "name": "ApiError",
    "fields": [
      {
        "name": "code",
        "type": "String",
        "description": "Error code"
      },
      {
        "name": "message",
        "type": "String",
        "description": "Error message"
      },
      {
        "name": "traceId",
        "type": "String",
        "description": "Trace ID for debugging"
      },
      {
        "name": "timestamp",
        "type": "String",
        "description": "Error timestamp"
      }
    ]
  },
  "useCases": [
    {
      "name": "GetScrumTeamsUseCase",
      "package": "tw.teddysoft.aiscrum.scrumteam.usecase.port.in"
    }
  ],
  "httpStatusCodes": [
    {
      "code": 200,
      "description": "Success - Returns list of teams"
    },
    {
      "code": 500,
      "description": "Internal server error"
    }
  ],
  "testScenarios": [
    {
      "name": "should_return_teams_list_when_teams_exist",
      "given": "Multiple teams exist in the system",
      "when": "GET request to /v1/api/scrum-teams",
      "then": "Returns 200 with teams list"
    },
    {
      "name": "should_return_empty_list_when_no_teams_exist",
      "given": "No teams exist in the system",
      "when": "GET request to /v1/api/scrum-teams",
      "then": "Returns 200 with empty teams list"
    },
    {
      "name": "should_return_500_when_use_case_fails",
      "given": "GetScrumTeamsUseCase fails",
      "when": "GET request to /v1/api/scrum-teams",
      "then": "Returns 500 with error details"
    }
  ],
  "policies": {
    "domainExposure": {
      "pattern": "read-only-entity",
      "rules": [
        "Controller may serialize ScrumTeamDto values returned by GetScrumTeamsUseCase.",
        "Controller must not map ScrumTeamDto back to ScrumTeamDto.",
        "Controller must not expose mutable ScrumTeam entity or mutable collection."
      ]
    }
  }
}
