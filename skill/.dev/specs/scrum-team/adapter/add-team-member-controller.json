{
  "useCase": "AddTeamMemberController",
  "behavior": "Add a member to an existing ScrumTeam.",
  "spec": {
    "basePath": "/v1/api/scrum-teams",
    "endpoints": [
      {
        "method": "POST",
        "path": "/{teamId}/members",
        "summary": "Add team member",
        "useCase": "AddTeamMemberUseCase",
        "mapping": {
          "input": { 
            "type": "body", 
            "dto": "AddTeamMemberRequest",
            "pathVariables": ["teamId"]
          },
          "output": { "mode": "async-202", "operationId": true }
        },
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "responses": {
          "202": { "body": "AcceptedResponse", "headers": ["Location","Operation-Id"] },
          "400": { "body": "ApiError" },
          "401": { "body": "ApiError" },
          "403": { "body": "ApiError" },
          "404": { "body": "ApiError" },
          "409": { "body": "ApiError" }
        },
        "headers": {
          "request": ["Idempotency-Key"],
          "response": ["Location","Operation-Id","traceId"]
        }
      }
    ],
    "errorMapping": [
      { "domain": "TeamNotFound", "http": 404, "code": "TEAM_NOT_FOUND" },
      { "domain": "DuplicateMember", "http": 409, "code": "DUPLICATE_MEMBER" },
      { "domain": "InvalidRole", "http": 400, "code": "INVALID_ROLE" }
    ]
  },
  "contracts": {
    "dtos": [
      {
        "name": "AddTeamMemberRequest",
        "fields": [
          { "name": "userId", "type": "string", "minLength": 1, "maxLength": 100 },
          { "name": "role", "type": "string", "enum": ["PO", "SM", "DEVELOPER", "STAKEHOLDER"] }
        ]
      },
      {
        "name": "AcceptedResponse",
        "fields": [
          { "name": "operationId", "type": "string" },
          { "name": "status", "type": "string", "example": "ACCEPTED" }
        ]
      },
      {
        "name": "ApiError",
        "fields": [
          { "name": "code", "type": "string" },
          { "name": "message", "type": "string" },
          { "name": "traceId", "type": "string" }
        ]
      }
    ]
  },
  "policies": {
    "validation": [
      { "target": "path.teamId", "rules": ["notBlank"] },
      { "target": "body.userId", "rules": ["notBlank","length<=100"] },
      { "target": "body.role", "rules": ["notBlank","in:PO,SM,DEVELOPER,STAKEHOLDER"] }
    ],
    "idempotency": { "header": "Idempotency-Key", "ttlSeconds": 600 },
    "observability": { "logging": "request-and-error", "tracing": true, "metrics": true }
  }
}