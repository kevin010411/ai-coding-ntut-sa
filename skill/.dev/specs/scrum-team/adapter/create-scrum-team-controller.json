{
  "useCase": "CreateScrumTeamController",
  "behavior": "Create a new ScrumTeam aggregate.",
  "spec": {
    "basePath": "/v1/api/scrum-teams",
    "endpoints": [
      {
        "method": "POST",
        "path": "",
        "summary": "Create scrum team",
        "useCase": "CreateScrumTeamUseCase",
        "mapping": {
          "input": { "type": "body", "dto": "CreateScrumTeamRequest" },
          "output": { "mode": "async-202", "operationId": true }
        },
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "responses": {
          "202": { "body": "AcceptedResponse", "headers": ["Location","Operation-Id"] },
          "400": { "body": "ApiError" },
          "401": { "body": "ApiError" },
          "403": { "body": "ApiError" },
          "409": { "body": "ApiError" }
        },
        "headers": {
          "request": ["Idempotency-Key"],
          "response": ["Location","Operation-Id","traceId"]
        }
      }
    ],
    "errorMapping": [
      { "domain": "DuplicateScrumTeamId", "http": 409, "code": "DUPLICATE_SCRUM_TEAM" },
      { "domain": "InvalidTeamName", "http": 400, "code": "INVALID_TEAM_NAME" }
    ]
  },
  "contracts": {
    "dtos": [
      {
        "name": "CreateScrumTeamRequest",
        "fields": [
          { "name": "teamId", "type": "string", "nullable": true, "note": "client-supplied optional" },
          { "name": "name", "type": "string", "minLength": 1, "maxLength": 100 },
          { "name": "description", "type": "string", "nullable": true, "maxLength": 500 },
          { "name": "note", "type": "string", "nullable": true, "maxLength": 1000 },
          { "name": "extension", "type": "string", "nullable": true },
          { "name": "creatorId", "type": "string", "minLength": 1, "maxLength": 100 }
        ]
      },
      {
        "name": "AcceptedResponse",
        "fields": [
          { "name": "operationId", "type": "string" },
          { "name": "status", "type": "string", "example": "ACCEPTED" }
        ]
      },
      {
        "name": "ApiError",
        "fields": [
          { "name": "code", "type": "string" },
          { "name": "message", "type": "string" },
          { "name": "traceId", "type": "string" }
        ]
      }
    ]
  },
  "policies": {
    "validation": [
      { "target": "body.name", "rules": ["notBlank","length<=100"] },
      { "target": "body.creatorId", "rules": ["notBlank","length<=100"] }
    ],
    "idempotency": { "header": "Idempotency-Key", "ttlSeconds": 600 },
    "observability": { "logging": "request-and-error", "tracing": true, "metrics": true }
  }
}