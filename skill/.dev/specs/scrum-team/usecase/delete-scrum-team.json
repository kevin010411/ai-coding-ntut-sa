{
  "useCase": "DeleteScrumTeam",
  "behavior": "Delete a scrum team",
  "input": [
    { "name": "scrumTeamId", "type": "String", "note": "ScrumTeam 的唯一識別碼" },
    { "name": "userId", "type": "String", "note": "刪除 ScrumTeam 的使用者" }
  ],
  "aggregate": "ScrumTeam",
  "aggregateId": "ScrumTeamId",
  "method": "ScrumTeam.markAsDelete",
  "domainEvent": "ScrumTeamEvents.ScrumTeamDeleted",
  "repository": "ScrumTeamRepository",
  "output": "CqrsOutput with scrumTeamId",
  "domainModelNotes": [
  ],
  "domainEvents": [
    {
      "name": "ScrumTeamEvents.ScrumTeamDeleted",
      "description": "Scrum team 被標注刪除",
      "attributes": [
        { "name": "scrumTeamId", "type": "ScrumTeamId" },
        { "name": "userId", "type": "String" }
      ]
    }
  ]
}