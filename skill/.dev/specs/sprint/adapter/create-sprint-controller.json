{
  "useCase": "CreateSprintController",
  "behavior": "Create a new Sprint for a Product",
  "canonicalResourcePath": "/v1/api/sprints/{sprintId}",
  "spec": {
    "basePath": "/v1/api/products/{productId}/sprints",
    "endpoints": [
      {
        "method": "POST",
        "path": "",
        "summary": "Create Sprint",
        "useCase": "CreateSprintUseCase",
        "mapping": {
          "input": { "type": "body", "dto": "CreateSprintRequest" },
          "pathVars": ["productId"],
          "output": { "mode": "async-202", "operationId": true }
        },
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "security": { "auth": "jwt-required", "roles": ["SPRINT_WRITE", "PRODUCT_WRITE"] },
        "responses": {
          "202": { "body": "AcceptedResponse", "headers": ["Location", "Operation-Id"] },
          "400": { "body": "ApiError" },
          "401": { "body": "ApiError" },
          "403": { "body": "ApiError" },
          "404": { "body": "ApiError" },
          "409": { "body": "ApiError" }
        },
        "headers": {
          "request": ["Idempotency-Key"],
          "response": ["Location", "Operation-Id", "traceId"]
        }
      }
    ],
    "errorMapping": [
      { "domain": "ProductNotFound", "http": 404, "code": "PRODUCT_NOT_FOUND" },
      { "domain": "DuplicateSprintId", "http": 409, "code": "DUPLICATE_SPRINT" },
      { "domain": "InvalidSprintName", "http": 400, "code": "INVALID_SPRINT_NAME" },
      { "domain": "InvalidTimebox", "http": 400, "code": "INVALID_TIMEBOX" },
      { "domain": "InvalidCapacity", "http": 400, "code": "INVALID_CAPACITY" }
    ]
  },
  "contracts": {
    "dtos": [
      {
        "name": "CreateSprintRequest",
        "fields": [
          { "name": "sprintId", "type": "string", "required": false, "maxLength": 64, "note": "client-supplied optional; server generates if absent" },
          { "name": "name", "type": "string", "required": true, "minLength": 1, "maxLength": 100, "description": "Sprint display name" },
          { "name": "goal", "type": "string", "required": false, "maxLength": 512, "description": "Sprint goal description" },
          { "name": "startDateTime", "type": "string", "required": true, "format": "date-time", "description": "Sprint start time in ISO 8601 format" },
          { "name": "endDateTime", "type": "string", "required": true, "format": "date-time", "description": "Sprint end time in ISO 8601 format" },
          { "name": "zoneId", "type": "string", "required": true, "maxLength": 50, "description": "Time zone ID, e.g., 'Asia/Taipei'" },
          { "name": "state", "type": "string", "required": true, "enum": ["PLANNED", "STARTED", "COMPLETED", "CANCELLED"], "description": "Initial sprint state" },
          { "name": "capacity", "type": "number", "required": false, "minimum": 0, "maximum": 10000, "multipleOf": 0.5, "description": "Sprint capacity in hours, e.g., 80, 160.5" },
          { "name": "dailyScrum", "type": "SprintMeetingDto", "required": false, "description": "Daily Scrum meeting information" },
          { "name": "review", "type": "SprintMeetingDto", "required": false, "description": "Sprint Review meeting information" },
          { "name": "retrospective", "type": "SprintMeetingDto", "required": false, "description": "Sprint Retrospective meeting information" },
          { "name": "note", "type": "string", "required": false, "maxLength": 1000, "description": "Additional sprint notes" },
          { "name": "creatorId", "type": "string", "serverDerived": true, "note": "taken from JWT; not from request body" }
        ]
      },
      {
        "name": "SprintMeetingDto",
        "fields": [
          { "name": "scheduledAt", "type": "string", "required": true, "format": "date-time", "description": "Meeting scheduled time in ISO 8601 format (required)" },
          { "name": "venue", "type": "string", "required": false, "maxLength": 200, "description": "Meeting venue or location (optional)" },
          { "name": "duration", "type": "string", "required": false, "format": "duration", "description": "Meeting duration in ISO 8601 duration format, e.g., 'PT15M', 'PT2H' (optional)" }
        ]
      },
      {
        "name": "AcceptedResponse",
        "fields": [
          { "name": "operationId", "type": "string" },
          { "name": "status", "type": "string", "default": "ACCEPTED" }
        ]
      },
      {
        "name": "ApiError",
        "fields": [
          { "name": "code", "type": "string" },
          { "name": "message", "type": "string" },
          { "name": "traceId", "type": "string" }
        ]
      }
    ]
  },
  "policies": {
    "validation": [
      { "target": "path.productId", "rules": ["notBlank", "length<=64"] },
      { "target": "body.name", "rules": ["notBlank", "length<=100"] },
      { "target": "body.startDateTime", "rules": ["notNull", "dateTime"] },
      { "target": "body.endDateTime", "rules": ["notNull", "dateTime"] },
      { "target": "body.zoneId", "rules": ["notBlank", "length<=50"] },
      { "target": "body.state", "rules": ["notBlank", "enum:PLANNED,STARTED,COMPLETED,CANCELLED"] },
      { "target": "header.Idempotency-Key", "rules": ["notBlank", "length<=64"] }
    ],
    "businessRules": [
      { "rule": "endDateTime must be after startDateTime", "validation": "custom" },
      { "rule": "zoneId must be valid timezone", "validation": "custom" },
      { "rule": "capacity must be positive if provided", "validation": "custom" }
    ],
    "idempotency": { "header": "Idempotency-Key", "ttlSeconds": 600 },
    "observability": { "logging": "request-and-error", "tracing": true, "metrics": true },
    "async": { "operationLocationTemplate": "/v1/api/operations/{operationId}" }
  }
}