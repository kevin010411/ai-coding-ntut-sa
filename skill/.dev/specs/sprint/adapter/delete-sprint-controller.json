{
  "controller": "DeleteSprintController",
  "type": "REST",
  "aggregate": "Sprint",
  "useCase": "DeleteSprintUseCase",
  "method": "DELETE",
  "path": "/sprints/{sprintId}",
  "pathVariables": [
    {
      "name": "sprintId",
      "type": "String",
      "description": "Sprint的唯一識別碼"
    }
  ],
  "headers": [
    {
      "name": "userId",
      "type": "String",
      "required": true,
      "description": "執行刪除操作的使用者ID"
    }
  ],
  "request": {
    "type": "none",
    "description": "DELETE請求不需要request body"
  },
  "response": {
    "type": "CqrsOutput",
    "status": "202 Accepted",
    "description": "回傳包含sprintId的CqrsOutput"
  },
  "errorHandling": [
    {
      "condition": "Sprint不存在",
      "status": "404 Not Found",
      "response": "錯誤訊息"
    },
    {
      "condition": "缺少userId header",
      "status": "400 Bad Request",
      "response": "Missing required header: userId"
    }
  ],
  "tests": [
    {
      "type": "unit",
      "class": "DeleteSprintControllerTest",
      "scenarios": [
        "成功刪除Sprint",
        "Sprint不存在",
        "缺少userId header"
      ]
    },
    {
      "type": "integration",
      "class": "DeleteSprintControllerIntegrationTest",
      "scenarios": [
        "完整的刪除流程測試",
        "錯誤處理測試"
      ]
    }
  ],
  "notes": [
    "參考DeleteProductController的實作模式",
    "使用@DeleteMapping註解",
    "確保正確處理PathVariable和RequestHeader",
    "回傳202 Accepted狀態碼表示非同步處理"
  ]
}