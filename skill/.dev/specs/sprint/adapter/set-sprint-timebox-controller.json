{
  "useCase": "SetSprintTimeboxController",
  "behavior": "Set or update the timebox (start and end dates) for an existing Sprint",
  "canonicalResourcePath": "/v1/api/sprints/{sprintId}/timebox",
  "spec": {
    "basePath": "/v1/api/products/{productId}/sprints/{sprintId}/timebox",
    "endpoints": [
      {
        "method": "PUT",
        "path": "",
        "summary": "Set Sprint Timebox",
        "useCase": "SetSprintTimeboxUseCase",
        "mapping": {
          "input": { "type": "body", "dto": "SetSprintTimeboxRequest" },
          "pathVars": ["productId", "sprintId"],
          "output": { "mode": "async-202", "operationId": true }
        },
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "security": { "auth": "jwt-required", "roles": ["SPRINT_WRITE"] },
        "responses": {
          "202": { "body": "AcceptedResponse", "headers": ["Location", "Operation-Id"] },
          "400": { "body": "ApiError" },
          "401": { "body": "ApiError" },
          "403": { "body": "ApiError" },
          "404": { "body": "ApiError" },
          "409": { "body": "ApiError" }
        },
        "headers": {
          "request": ["Idempotency-Key"],
          "response": ["Location", "Operation-Id", "traceId"]
        }
      }
    ],
    "errorMapping": [
      { "domain": "ProductNotFound", "http": 404, "code": "PRODUCT_NOT_FOUND" },
      { "domain": "SprintNotFound", "http": 404, "code": "SPRINT_NOT_FOUND" },
      { "domain": "InvalidTimebox", "http": 400, "code": "INVALID_TIMEBOX" },
      { "domain": "TimeboxOverlap", "http": 409, "code": "TIMEBOX_OVERLAP" },
      { "domain": "SprintInInvalidState", "http": 400, "code": "SPRINT_INVALID_STATE" },
      { "domain": "InvalidTimeZone", "http": 400, "code": "INVALID_TIMEZONE" }
    ]
  },
  "contracts": {
    "dtos": [
      {
        "name": "SetSprintTimeboxRequest",
        "fields": [
          { "name": "startDateTime", "type": "string", "required": true, "format": "date-time", "description": "Sprint start time in ISO 8601 format, e.g., '2024-01-15T09:00:00'" },
          { "name": "endDateTime", "type": "string", "required": true, "format": "date-time", "description": "Sprint end time in ISO 8601 format, e.g., '2024-01-29T18:00:00'" },
          { "name": "zoneId", "type": "string", "required": true, "minLength": 1, "maxLength": 50, "description": "Time zone ID, e.g., 'Asia/Taipei', 'UTC', 'America/New_York'" },
          { "name": "note", "type": "string", "required": false, "maxLength": 1000, "description": "Additional notes about the timebox change" }
        ]
      },
      {
        "name": "AcceptedResponse",
        "fields": [
          { "name": "operationId", "type": "string" },
          { "name": "status", "type": "string", "default": "ACCEPTED" }
        ]
      },
      {
        "name": "ApiError",
        "fields": [
          { "name": "code", "type": "string" },
          { "name": "message", "type": "string" },
          { "name": "traceId", "type": "string" }
        ]
      }
    ]
  },
  "policies": {
    "validation": [
      { "target": "path.productId", "rules": ["notBlank", "length<=64"] },
      { "target": "path.sprintId", "rules": ["notBlank", "length<=64"] },
      { "target": "body.startDateTime", "rules": ["notNull", "dateTime"] },
      { "target": "body.endDateTime", "rules": ["notNull", "dateTime"] },
      { "target": "body.zoneId", "rules": ["notBlank", "length<=50"] },
      { "target": "header.Idempotency-Key", "rules": ["notBlank", "length<=64"] }
    ],
    "businessRules": [
      { "rule": "endDateTime must be after startDateTime", "validation": "custom" },
      { "rule": "Sprint duration must be between 1 day and 4 weeks", "validation": "custom" },
      { "rule": "zoneId must be valid timezone identifier", "validation": "custom" },
      { "rule": "Sprint must be in PLANNED state for timebox changes", "validation": "custom" },
      { "rule": "New timebox cannot overlap with other active sprints in same product", "validation": "custom" }
    ],
    "idempotency": { "header": "Idempotency-Key", "ttlSeconds": 600 },
    "observability": { "logging": "request-and-error", "tracing": true, "metrics": true },
    "async": { "operationLocationTemplate": "/v1/api/operations/{operationId}" }
  }
}