{
  "controller": "StartSprintController",
  "description": "REST controller for starting a sprint",
  "baseUrl": "/api/sprints/{sprintId}/start",
  "method": "POST",
  "pathVariables": [
    { "name": "sprintId", "type": "String", "description": "Sprint ID" }
  ],
  "requestBody": {
    "type": "StartSprintRequest",
    "fields": [
      { "name": "productId", "type": "String", "required": true, "description": "Product ID" },
      { "name": "occurredOn", "type": "LocalDateTime", "required": false, "description": "Optional timestamp when the sprint was started" }
    ]
  },
  "responses": [
    {
      "status": 202,
      "description": "Sprint started successfully",
      "body": {
        "type": "StartSprintResponse",
        "fields": [
          { "name": "sprintId", "type": "String" },
          { "name": "status", "type": "String", "value": "STARTED" }
        ]
      }
    },
    {
      "status": 400,
      "description": "Bad request - validation errors",
      "body": {
        "type": "ErrorResponse",
        "fields": [
          { "name": "error", "type": "String" },
          { "name": "message", "type": "String" }
        ]
      }
    },
    {
      "status": 404,
      "description": "Sprint not found",
      "body": {
        "type": "ErrorResponse",
        "fields": [
          { "name": "error", "type": "String" },
          { "name": "message", "type": "String" }
        ]
      }
    },
    {
      "status": 409,
      "description": "Conflict - Sprint not in valid state for starting",
      "body": {
        "type": "ErrorResponse",
        "fields": [
          { "name": "error", "type": "String" },
          { "name": "message", "type": "String" }
        ]
      }
    }
  ],
  "validation": [
    "productId must not be blank",
    "sprintId must not be blank",
    "occurredOn is optional, if provided must be a valid date time"
  ],
  "useCase": "StartSprintUseCase",
  "useCaseInput": {
    "mapping": [
      { "from": "productId", "to": "productId" },
      { "from": "sprintId", "to": "sprintId" },
      { "from": "occurredOn", "to": "occurredOn" }
    ]
  }
}