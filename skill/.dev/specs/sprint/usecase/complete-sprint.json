{
  "useCase": "CompleteSprint",
  "behavior": "Complete a sprint and set its status to completed",
  "input": [
    { "name": "productId", "type": "String", "note": "Product 的唯一識別碼" },
    { "name": "sprintId", "type": "String", "note": "Sprint 的唯一識別碼" },
    { "name": "occurredOn", "type": "Date", "note": "optional, when the sprint was completed" }
  ],
  "aggregate": "Sprint",
  "aggregateId": "SprintId",
  "method": "Sprint.complete(Date occurredOn)",
  "domainEvent": ["SprintEvents.SprintCompleted"],
  "repository": "SprintRepository",
  "output": "CqrsOutput with sprintId",
  "domainModelNotes": [
    "requireNotNull(\"Sprint ID is not null\", ()-> sprintId)",
    "require(\"Sprint is not already completed\", ()-> !status.equals(SprintStatus.COMPLETED))",
    "ensure(\"Sprint status is completed\", () -> status.equals(SprintStatus.COMPLETED))"
  ],
  "domainEvents": [
    {
      "name": "SprintEvents.SprintCompleted",
      "description": "Sprint 完成",
      "attributes": [
        { "name": "productId", "type": "ProductId",  "constraint": "non-null" },
        { "name": "sprintId", "type": "SprintId",  "constraint": "non-null" },
        { "name": "occurredOn", "type": "Date",  "constraint": "non-null, use input.occurredOn if provided, otherwise use current date" }
      ]
    }
  ]
}