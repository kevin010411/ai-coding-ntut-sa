{
  "useCase": "DeleteSprint",
  "behavior": "Delete a sprint",
  "input": [
    { "name": "sprintId", "type": "String", "note": "Sprint 的唯一識別碼" },
    { "name": "userId", "type": "String", "note": "刪除 Sprint 的使用者" }
  ],
  "aggregate": "Sprint",
  "aggregateId": "SprintId",
  "method": "Sprint.markAsDelete",
  "domainEvent": "SprintEvents.SprintDeleted",
  "repository": "SprintRepository",
  "output": "CqrsOutput with sprintId",
  "domainModelNotes": [
  ],
  "domainEvents": [
    {
      "name": "SprintEvents.SprintDeleted",
      "description": "Sprint 被標注刪除",
      "attributes": [
        { "name": "sprintId", "type": "SprintId" },
        { "name": "userId", "type": "String" }
      ]
    }
  ]
}