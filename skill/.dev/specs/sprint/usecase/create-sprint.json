{
  "useCase": "CreateSprint",
  "behavior": "Create a new sprint",
  "input": [
    { "name": "productId", "type": "String", "note": "Product 的唯一識別碼" },
    { "name": "sprintId", "type": "String", "note": "Sprint 的唯一識別碼" },
    { "name": "name", "type": "String", "note": "Sprint 的顯示名稱" },
    { "name": "goal", "type": "String", "note": "Sprint Goal" },
    { "name": "startDateTime", "type": "LocalDateTime", "note": "Sprint 預計開始時間" },
    { "name": "endDateTime", "type": "LocalDateTime", "note": "Sprint 結束時間" },
    { "name": "zoneId", "type": "String", "note": "時區 id，e.g., \"Asia/Taipei\"" },
    { "name": "state", "type": "String", "note": "Sprint 狀態" },
    { "name": "capacity", "type": "String", "note": "Sprint 總工時" },
    { "name": "dailyScrum", "type": "SprintMeetingInput", "note": "Daily Scrum 會議資訊" },
    { "name": "review", "type": "SprintMeetingInput", "note": "Sprint Review 會議資訊" },
    { "name": "retrospective", "type": "SprintMeetingInput", "note": "Sprint Retrospective 會議資訊" },
    { "name": "creatorId", "type": "String", "note": "建立 Product 的使用者 ID, 紀錄在領域事件中" }
  ],
  "aggregate": "Sprint",
  "aggregateId": "SprintId",
  "method": "Sprint constructor",
  "domainEvent": "SprintEvents.SprintCreated",
  "repository": "SprintRepository",
  "output": "CqrsOutput with sprintId",
  "domainModelNotes": [
    "Sprint 使用建構函數建立新實例"
  ],
  "constructorPreconditions": [
    {
      "rule": "Required fields validation",
      "description": "必要欄位都必須通過 requireNotNull() 檢查",
      "fields": ["productId", "sprintId", "name", "timebox", "state", "creatorId"]
    },
    {
      "rule": "Timebox validation",
      "description": "Timebox 的結束時間必須在開始時間之後",
      "validation": "require('End date must be after start date', () -> timebox.end().isAfter(timebox.start()))"
    }
  ],
  "constructorPostconditions": [
    {
      "rule": "Field assignment verification",
      "description": "使用 ensure() 檢查所有欄位都正確設定",
      "checks": [
        "Sprint id is set correctly",
        "Sprint name is set correctly",
        "Product id is set correctly",
        "Sprint state is set correctly",
        "Sprint timebox is set correctly",
        "Sprint goal matches input (nullable)",
        "Sprint note matches input (nullable)",
        "Creator id is set correctly",
        "Sprint extension matches input (nullable)",
        "Sprint meetings match input (nullable)",
        "Sprint board config is set (default if null)"
      ]
    },
    {
      "rule": "Domain event verification",
      "description": "確保 SprintCreated 領域事件正確產生",
      "validation": "最後一個領域事件必須是 SprintCreated 且包含所有正確欄位值"
    }
  ],
  "aggregates": [
    {
      "name": "Sprint",
      "description": "Sprint",
      "attributes": [
        { "name": "productId", "type": "ProductId",  "constraint": "non-null" },
        { "name": "id", "type": "SprintId",  "constraint": "non-null" },
        { "name": "name", "type": "SprintName","constraint": "non-null" },
        { "name": "goal", "type": "SprintGoal",  "constraint": "nullable" },
        { "name": "timebox", "type": "Timebox",  "constraint": "non-null" },
        { "name": "state", "type": "SprintState",  "constraint": "non-null" },
        { "name": "capacity", "type": "CapacityHours",  "constraint": "nullable" },
        { "name": "dailyScrum", "type": "SprintMeeting", "constraint": "nullable" },
        { "name": "review", "type": "SprintMeeting", "constraint": "nullable" },
        { "name": "retrospective", "type": "SprintMeeting", "constraint": "nullable" },
        { "name": "note", "type": "String", "constraint": "nullable" },
        { "name": "creatorId", "type": "String", "constraint": "non-null"},
        { "name": "extension", "type": "String", "constraint": "nullable" }
      ]
    }
  ],
  "domainEvents": [
    {
      "name": "Sprint.SprintCreated",
      "description": "Sprint 已建立",
      "attributes": [
        { "name": "productId", "type": "ProductId",  "constraint": "non-null" },
        { "name": "sprintId", "type": "SprintId",  "constraint": "non-null" },
        { "name": "name", "type": "SprintName","constraint": "non-null" },
        { "name": "goal", "type": "SprintGoal",  "constraint": "nullable" },
        { "name": "timebox", "type": "Timebox",  "constraint": "non-null" },
        { "name": "state", "type": "SprintState",  "constraint": "non-null" },
        { "name": "capacity", "type": "CapacityHours",  "constraint": "nullable" },
        { "name": "dailyScrum", "type": "SprintMeeting", "constraint": "nullable" },
        { "name": "review", "type": "SprintMeeting", "constraint": "nullable" },
        { "name": "retrospective", "type": "SprintMeeting", "constraint": "nullable" },
        { "name": "note", "type": "String", "constraint": "nullable" },
        { "name": "creatorId", "type": "String", "constraint": "non-null"},
        { "name": "extension", "type": "String", "constraint": "nullable" }
      ]
    }
  ],
  "valueObjects": [
    {
      "name": "SprintGoal",
      "description": "Sprint 目標",
      "fields": [
        { "name": "value", "type": "String" }
      ]
    },
    {
      "name": "Timebox",
      "description": "Sprint 期間",
      "fields": [
        { "name": "start", "type": "LocalDateTime" },
        { "name": "end", "type": "LocalDateTime" },
        { "name": "zoneId", "type": "ZoneId" }
      ]
    },
    {
      "name": "CapacityHours",
      "description": "Sprint 可用工時容量",
      "fields": [
        { "name": "value", "type": "Hours" }
      ]
    },
    {
      "name": "SprintMeeting",
      "description": "Sprint 會議資訊",
      "fields": [
        { "name": "scheduledAt", "type": "Instant" },
        { "name": "venue", "type": "String" },
        { "name": "duration", "type": "Duration" }
      ]
    }
  ],
  "enums": [
    {
      "name": "SprintState",
      "description": "Sprint 目前狀態",
      "values": ["PLANNED","STARTED", "COMPLETED","CANCELLED"]
    }
  ]
}