{
  "useCase": "SetSprintTimebox",
  "behavior": "Set sprint timebox",
  "input": [
    { "name": "productId", "type": "String", "note": "Product 的唯一識別碼" },
    { "name": "sprintId", "type": "String", "note": "Sprint 的唯一識別碼" },
    { "name": "start", "type": "LocalDateTime", "note": "Sprint 開始日期" },
    { "name": "end", "type": "LocalDateTime", "note": "Sprint 結束日期" },
    { "name": "zoneId", "type": "ZoneId", "note": "Sprint 開始與結束日期時區" }
  ],
  "aggregate": "Sprint",
  "aggregateId": "SprintId",
  "method": "Sprint.setTimebox",
  "domainEvent": "SprintEvents.SprintTimeboxSet",
  "repository": "SprintRepository",
  "output": "CqrsOutput with sprintId",
  "domainModelNotes": [
  ],
  "domainEvents": [
    {
      "name": "Sprint.SprintTimeboxSet",
      "description": "Sprint Timebox 已設定",
      "attributes": [
        { "name": "productId", "type": "ProductId",  "constraint": "non-null" },
        { "name": "sprintId", "type": "SprintId",  "constraint": "non-null" },
        { "name": "timebox", "type": "Timebox",  "constraint": "non-null" }
      ]
    }
  ]
}