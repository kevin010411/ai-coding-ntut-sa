{
  "useCase": "StartSprint",
  "behavior": "Start a sprint by changing its status to STARTED",
  "input": [
    { "name": "productId", "type": "String", "note": "Product 的唯一識別碼" },
    { "name": "sprintId", "type": "String", "note": "Sprint 的唯一識別碼" },
    { "name": "occurredOn", "type": "LocalDateTime", "note": "optional - when the sprint was started" }
  ],
  "aggregate": "Sprint",
  "aggregateId": "SprintId",
  "method": "Sprint.start(LocalDateTime occurredOn)",
  "domainEvent": ["SprintEvents.SprintStarted"],
  "repository": "SprintRepository",
  "output": "CqrsOutput with sprintId",
  "domainModelNotes": [
    "requireNotNull(\"Sprint ID is not null\", ()-> sprintId)",
    "require(\"Sprint status is CREATED\", ()-> this.status == SprintStatus.CREATED)",
    "ensure(\"Sprint status is STARTED\", () -> this.status == SprintStatus.STARTED)"
  ],
  "domainEvents": [
    {
      "name": "SprintEvents.SprintStarted",
      "description": "Sprint 被啟動",
      "attributes": [
        { "name": "productId", "type": "ProductId", "constraint": "non-null" },
        { "name": "sprintId", "type": "SprintId", "constraint": "non-null" },
        { "name": "status", "type": "SprintStatus", "constraint": "non-null, value is STARTED" }
      ]
    }
  ]
}