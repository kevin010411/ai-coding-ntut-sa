{
  "useCase": "CreateProductBacklogItemController",
  "behavior": "Create a new PBI",
  "spec": {
    "basePath": "/v1/api/products/{productId}/pbis",
    "endpoints": [
      {
        "method": "POST",
        "path": "",
        "summary": "Create PBI",
        "useCase": "CreateProductBacklogItemUseCase",
        "mapping": {
          "input": { 
            "type": "body", 
            "dto": "CreateProductBacklogItemRequest",
            "pathVars": ["productId"]
          },
          "output": { "mode": "async-202", "operationId": true }
        },
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "responses": {
          "202": { "body": "AcceptedResponse", "headers": ["Location","Operation-Id"] },
          "400": { "body": "ApiError" },
          "401": { "body": "ApiError" },
          "403": { "body": "ApiError" },
          "409": { "body": "ApiError" }
        },
        "headers": {
          "request": ["Idempotency-Key"],
          "response": ["Location","Operation-Id","traceId"]
        }
      }
    ],
    "errorMapping": [
      { "domain": "ProductNotFound", "http": 404, "code": "PRODUCT_NOT_FOUND" },
      { "domain": "DuplicateProductBacklogItemId", "http": 409, "code": "DUPLICATE_PRODUCT_BACKLOG_ITEM" },
      { "domain": "InvalidName", "http": 400, "code": "INVALID_NAME" }
    ]
  },
  "contracts": {
    "dtos": [
      {
        "name": "CreateProductBacklogItemRequest",
        "fields": [
          { "name": "pbiId", "type": "string", "nullable": true, "note": "client-supplied optional" },
          { "name": "name", "type": "String", "minLength": 1, "maxLength": 100},
          { "name": "description", "type": "String", "minLength": 0, "maxLength": 256},
          { "name": "sprintId", "type": "String", "nullable": true, "note": "client-supplied optional" },
          { "name": "estimateValue", "type": "String", "minLength": 1, "maxLength": 100},
          {
            "name": "estimateType",
            "type": "enum",
            "values": ["STORY_POINT", "T_SHIRT_SIZE", "IDEAL_DAY", "USER_DEFINED", "NONE"],
            "required": true
          },
          { "name": "importance", "type": "String", "minLength": 1, "maxLength": 36},
          {
            "name": "pbiState",
            "type": "enum",
            "values": ["BACKLOGGED", "READY", "SELECTED"],
            "required": true
          }
        ]
      },
      {
        "name": "AcceptedResponse",
        "fields": [
          { "name": "operationId", "type": "string" },
          { "name": "status", "type": "string", "example": "ACCEPTED" }
        ]
      },
      {
        "name": "ApiError",
        "fields": [
          { "name": "code", "type": "string" },
          { "name": "message", "type": "string" },
          { "name": "traceId", "type": "string" }
        ]
      }
    ]
  },
  "policies": {
    "validation": [
      { "target": "path.productId", "rules": ["notBlank", "length<=64"] },
      { "target": "body.name", "rules": ["notBlank", "length<=100"] },
      { "target": "header.Idempotency-Key", "rules": ["optional", "length<=64"] }
    ],
    "idempotency": { "header": "Idempotency-Key", "ttlSeconds": 600 },
    "observability": { "logging": "request-and-error", "tracing": true, "metrics": true },
    "async": { "operationLocationTemplate": "/v1/api/operations/{operationId}" }
  }
}