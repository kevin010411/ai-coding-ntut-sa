{
  "restController": "GetTasksByProductBacklogItemController",
  "spec": {
    "basePath": "v1/api/pbis/{pbiId}/tasks",
    "endpoints": [
      {
        "method": "GET",
        "path": "",
        "useCase": "GetTasksByProductBacklogItemUseCase",
        "mapping": {
          "input": {
            "type": "path",
            "pathVars": [
              "pbiId"
            ]
          },
          "output": {
            "type": "list",
            "entity": "TaskReadOnly",
            "itemType": "readOnlyEntity"
          }
        },
        "responses": {
          "200": {
            "body": "List<TaskReadOnly>"
          },
          "400": {
            "body": "ApiError"
          },
          "401": {
            "body": "ApiError"
          },
          "500": {
            "body": "ApiError"
          }
        },
        "produces": [
          "application/json"
        ]
      }
    ]
  },
  "contracts": {
    "name": "ApiError",
    "fields": [
      {
        "name": "code",
        "type": "string",
        "example": "PBI_NOT_FOUND"
      },
      {
        "name": "message",
        "type": "string"
      },
      {
        "name": "traceId",
        "type": "string"
      }
    ]
  },
  "policies": {
    "validation": [
      {
        "target": "path.pbiId",
        "rules": [
          "notBlank"
        ]
      }
    ],
    "caching": {
      "etag": "optional",
      "cacheControl": "max-age=30, public"
    },
    "observability": {
      "logging": "request-and-error",
      "tracing": true,
      "metrics": true
    }
  },
  "testScenarios": [
    {
      "name": "should_return_200_with_task_list_when_pbi_has_tasks",
      "given": "PBI exists and contains multiple tasks",
      "when": "GET /v1/api/pbis/{pbiId}/tasks",
      "then": [
        "Returns HTTP 200",
        "Response body contains List<TaskReadOnly>",
        "Each TaskReadOnly contains all required fields (id, pbiId, name, state, etc.)",
        "Content-Type is application/json"
      ]
    },
    {
      "name": "should_return_200_with_empty_list_when_pbi_has_no_tasks",
      "given": "PBI exists but has no tasks",
      "when": "GET /v1/api/pbis/{pbiId}/tasks",
      "then": [
        "Returns HTTP 200",
        "Response body contains empty list []",
        "Content-Type is application/json"
      ]
    },
    {
      "name": "should_return_200_with_empty_list_when_pbi_not_found",
      "given": "PBI does not exist",
      "when": "GET /v1/api/pbis/{nonExistentPbiId}/tasks",
      "then": [
        "Returns HTTP 200",
        "Response body contains empty list []",
        "Content-Type is application/json"
      ]
    },
    {
      "name": "should_return_400_when_pbi_id_is_blank",
      "given": "PBI ID is blank or empty",
      "when": "GET /v1/api/pbis/ /tasks",
      "then": [
        "Returns HTTP 400",
        "Response body contains ApiError",
        "Error code indicates validation failure"
      ]
    },
    {
      "name": "should_return_401_when_unauthorized",
      "given": "Request lacks proper authentication",
      "when": "GET /v1/api/pbis/{pbiId}/tasks without auth token",
      "then": [
        "Returns HTTP 401",
        "Response body contains ApiError",
        "Error code indicates authentication required"
      ]
    }
  ],
  "implementation": {
    "controller": {
      "annotations": [
        "@RestController",
        "@RequestMapping(\"/v1/api/pbis\")",
        "@Tag(name = \"Product Backlog Item Tasks\", description = \"Operations for retrieving tasks of a PBI\")"
      ],
      "dependencies": [
        "GetTasksByProductBacklogItemUseCase"
      ]
    },
    "method": {
      "annotations": [
        "@GetMapping(\"/{pbiId}/tasks\")",
        "@Operation(summary = \"Get all tasks for a Product Backlog Item\")",
        "@ApiResponses(value = {...})"
      ],
      "parameters": [
        {
          "name": "pbiId",
          "type": "String",
          "annotation": "@PathVariable",
          "validation": "@NotBlank"
        }
      ],
      "returnType": "ResponseEntity<List<TaskReadOnly>>"
    }
  },
  "notes": [
    "Returns empty list instead of 404 when PBI not found (as per use case spec)",
    "Tasks are returned in their natural order from the domain",
    "All task fields are included in the response (including optional ones)",
    "Response is cacheable for 30 seconds to reduce database load"
  ]
}
