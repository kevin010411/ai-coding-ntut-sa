{
  "useCase": "CreateTaskController",
  "behavior": "Create a new Task for a Product Backlog Item",
  "canonicalResourcePath": "/v1/api/tasks/{taskId}",
  "spec": {
    "basePath": "/v1/api/pbis/{pbiId}/tasks",
    "endpoints": [
      {
        "method": "POST",
        "path": "",
        "summary": "Create Task",
        "useCase": "CreateTaskUseCase",
        "mapping": {
          "input": { "type": "body", "dto": "CreateTaskRequest" },
          "pathVars": ["pbiId"],
          "output": { "mode": "async-202", "operationId": true }
        },
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "security": { "auth": "jwt-required", "roles": ["TASK_WRITE", "PBI_WRITE"] },
        "responses": {
          "202": { "body": "AcceptedResponse", "headers": ["Location", "Operation-Id"] },
          "400": { "body": "ApiError" },
          "401": { "body": "ApiError" },
          "403": { "body": "ApiError" },
          "404": { "body": "ApiError" },
          "409": { "body": "ApiError" }
        },
        "headers": {
          "request": ["Idempotency-Key"],
          "response": ["Location", "Operation-Id", "traceId"]
        }
      }
    ],
    "errorMapping": [
      { "domain": "PbiNotFound", "http": 404, "code": "PBI_NOT_FOUND" },
      { "domain": "DuplicateTaskId", "http": 409, "code": "DUPLICATE_TASK" },
      { "domain": "InvalidTaskName", "http": 400, "code": "INVALID_TASK_NAME" },
      { "domain": "InvalidEstimatedHours", "http": 400, "code": "INVALID_ESTIMATED_HOURS" }
    ]
  },
  "contracts": {
    "dtos": [
      {
        "name": "CreateTaskRequest",
        "fields": [
          { "name": "productId", "type": "string", "required": true, "minLength": 1, "maxLength": 64, "description": "Product ID that contains the PBI" },
          { "name": "taskId", "type": "string", "required": false, "maxLength": 64, "note": "client-supplied optional; server generates if absent" },
          { "name": "name", "type": "string", "required": true, "minLength": 1, "maxLength": 100 },
          { "name": "estimatedHours", "type": "number", "required": true, "minimum": 0, "maximum": 1000, "description": "支援小數，如 0.5, 1.5, 2.8 等，內部使用 BigDecimal 儲存" },
          { "name": "creatorId", "type": "string", "serverDerived": true, "note": "taken from JWT; not from request body" }
        ]
      },
      {
        "name": "AcceptedResponse",
        "fields": [
          { "name": "operationId", "type": "string" },
          { "name": "status", "type": "string", "default": "ACCEPTED" }
        ]
      },
      {
        "name": "ApiError",
        "fields": [
          { "name": "code", "type": "string" },
          { "name": "message", "type": "string" },
          { "name": "traceId", "type": "string" }
        ]
      }
    ]
  },
  "policies": {
    "validation": [
      { "target": "path.pbiId", "rules": ["notBlank", "length<=64"] },
      { "target": "body.productId", "rules": ["notBlank", "length<=64"] },
      { "target": "body.name", "rules": ["notBlank", "length<=100"] },
      { "target": "header.Idempotency-Key", "rules": ["notBlank", "length<=64"] }
    ],
    "idempotency": { "header": "Idempotency-Key", "ttlSeconds": 600 },
    "observability": { "logging": "request-and-error", "tracing": true, "metrics": true },
    "async": { "operationLocationTemplate": "/v1/api/operations/{operationId}" }
  }
}