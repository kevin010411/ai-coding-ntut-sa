{
  "useCase": "SelectProductBacklogItemController",
  "behavior": "Select a PBI to a sprint",
  "canonicalResourcePath": "/v1/api/pbis/{pbiId}",
  "spec": {
    "basePath": "/v1/api/pbis/{pbiId}/select",
    "endpoints": [
      {
        "method": "POST",
        "path": "",
        "summary": "Select PBI to Sprint",
        "useCase": "SelectProductBacklogItemUseCase",
        "mapping": {
          "input": { 
            "type": "body", 
            "dto": "SelectPbiRequest",
            "pathVars": ["pbiId"]
          },
          "output": { 
            "mode": "async-202", 
            "operationId": true 
          }
        },
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "responses": {
          "202": { 
            "body": "AcceptedResponse", 
            "headers": ["Location", "Operation-Id"] 
          },
          "400": { "body": "ApiError" },
          "404": { "body": "ApiError" },
          "409": { "body": "ApiError" }
        },
        "headers": {
          "request": ["Idempotency-Key"],
          "response": ["Location", "Operation-Id", "traceId"]
        }
      }
    ],
    "errorMapping": [
      { "domain": "PbiNotFound", "http": 404, "code": "PBI_NOT_FOUND" },
      { "domain": "SprintNotFound", "http": 404, "code": "SPRINT_NOT_FOUND" },
      { "domain": "PbiAlreadySelected", "http": 409, "code": "PBI_ALREADY_SELECTED" },
      { "domain": "InvalidOperation", "http": 400, "code": "INVALID_OPERATION" }
    ]
  },
  "contracts": {
    "dtos": [
      {
        "name": "SelectPbiRequest",
        "fields": [
          { "name": "productId", "type": "string", "required": true, "minLength": 1, "maxLength": 64, "description": "Product ID that contains the PBI" },
          { "name": "sprintId", "type": "string", "required": true, "minLength": 1, "maxLength": 64, "description": "Sprint ID to select the PBI into" },
          { "name": "userId", "type": "string", "serverDerived": true, "note": "taken from JWT; not from request body" }
        ]
      },
      {
        "name": "AcceptedResponse",
        "fields": [
          { "name": "operationId", "type": "string" },
          { "name": "status", "type": "string", "default": "ACCEPTED" }
        ]
      },
      {
        "name": "ApiError",
        "fields": [
          { "name": "code", "type": "string" },
          { "name": "message", "type": "string" },
          { "name": "traceId", "type": "string" }
        ]
      }
    ]
  },
  "policies": {
    "validation": [
      { "target": "path.pbiId", "rules": ["notBlank", "length<=64"] },
      { "target": "body.productId", "rules": ["notBlank", "length<=64"] },
      { "target": "body.sprintId", "rules": ["notBlank", "length<=64"] }
    ],
    "idempotency": { 
      "header": "Idempotency-Key", 
      "ttlSeconds": 600 
    },
    "observability": { 
      "logging": "request-and-error", 
      "tracing": true, 
      "metrics": true 
    },
    "async": { 
      "operationLocationTemplate": "/v1/api/operations/{operationId}" 
    }
  }
}