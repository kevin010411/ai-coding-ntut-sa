{
  "useCase": "ReestimateTaskController",
  "behavior": "Reestimate a task and revise its remaining hours",
  "canonicalResourcePath": "/v1/api/pbis/{pbiId}/tasks/{taskId}",
  "spec": {
    "basePath": "/v1/api/pbis/{pbiId}/tasks/{taskId}/reestimate",
    "endpoints": [
      {
        "method": "PUT",
        "path": "",
        "summary": "Reestimate Task",
        "useCase": "ReestimateTaskUseCase",
        "mapping": {
          "input": { 
            "type": "body", 
            "dto": "ReestimateTaskRequest",
            "pathVars": ["pbiId", "taskId"]
          },
          "output": { 
            "mode": "async-202", 
            "operationId": true 
          }
        },
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "responses": {
          "202": { 
            "body": "AcceptedResponse", 
            "headers": ["Location", "Operation-Id"] 
          },
          "400": { "body": "ApiError" },
          "404": { "body": "ApiError" },
          "409": { "body": "ApiError" }
        },
        "headers": {
          "request": ["Idempotency-Key"],
          "response": ["Location", "Operation-Id", "traceId"]
        }
      }
    ],
    "errorMapping": [
      { "domain": "TaskNotFound", "http": 404, "code": "TASK_NOT_FOUND" },
      { "domain": "PbiNotFound", "http": 404, "code": "PBI_NOT_FOUND" },
      { "domain": "TaskNotEstimated", "http": 409, "code": "TASK_NOT_ESTIMATED" },
      { "domain": "InvalidEstimatedHours", "http": 400, "code": "INVALID_ESTIMATED_HOURS" }
    ]
  },
  "contracts": {
    "dtos": [
      {
        "name": "ReestimateTaskRequest",
        "fields": [
          { "name": "productId", "type": "string", "required": true, "minLength": 1, "maxLength": 64, "description": "Product ID that contains the PBI" },
          { "name": "estimatedHours", "type": "number", "required": true, "minimum": 0, "maximum": 1000, "description": "新的預估時數，支援小數如 0.5, 1.5, 2.8 等，內部使用 BigDecimal 儲存" },
          { "name": "reason", "type": "string", "required": false, "maxLength": 500, "description": "Reason for reestimation" }
        ]
      },
      {
        "name": "AcceptedResponse",
        "fields": [
          { "name": "operationId", "type": "string" },
          { "name": "status", "type": "string", "default": "ACCEPTED" }
        ]
      },
      {
        "name": "ApiError",
        "fields": [
          { "name": "code", "type": "string" },
          { "name": "message", "type": "string" },
          { "name": "traceId", "type": "string" }
        ]
      }
    ]
  },
  "policies": {
    "validation": [
      { "target": "path.pbiId", "rules": ["notBlank", "length<=64"] },
      { "target": "path.taskId", "rules": ["notBlank", "length<=64"] },
      { "target": "body.productId", "rules": ["notBlank", "length<=64"] },
      { "target": "body.estimatedHours", "rules": ["notNull", "min:0", "max:1000"] }
    ],
    "idempotency": { 
      "header": "Idempotency-Key", 
      "ttlSeconds": 600 
    },
    "observability": { 
      "logging": "request-and-error", 
      "tracing": true, 
      "metrics": true 
    },
    "async": { 
      "operationLocationTemplate": "/v1/api/operations/{operationId}" 
    }
  }
}