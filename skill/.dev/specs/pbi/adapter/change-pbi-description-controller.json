{
  "controller": "ChangeProductBacklogItemDescriptionController",
  "httpMethod": "POST",
  "path": "/v1/api/products/{productId}/pbis/{pbiId}/change-description",
  "pathVariables": [
    { "name": "productId", "type": "String", "description": "Product ID" },
    { "name": "pbiId", "type": "String", "description": "PBI ID" }
  ],
  "requestBody": {
    "fields": [
      { "name": "newDescription", "type": "String", "constraint": "non-null, @NotNull", "description": "New description for the PBI" },
      { "name": "occurredOn", "type": "LocalDateTime", "constraint": "optional", "description": "Event timestamp" }
    ]
  },
  "useCase": "ChangeProductBacklogItemDescriptionUseCase",
  "successStatusCode": "202 ACCEPTED",
  "response": {
    "success": {
      "fields": [
        { "name": "pbiId", "type": "String", "description": "ID of the modified PBI" },
        { "name": "description", "type": "String", "description": "New description" }
      ]
    }
  },
  "errorCodes": [
    { "code": "INVALID_PRODUCT_ID", "status": 400, "condition": "productId is null or 'null' string" },
    { "code": "INVALID_PBI_ID", "status": 400, "condition": "pbiId is null or 'null' string" },
    { "code": "INVALID_DESCRIPTION", "status": 400, "condition": "newDescription is null" },
    { "code": "PBI_NOT_FOUND", "status": 404, "condition": "PBI not found" },
    { "code": "INTERNAL_ERROR", "status": 500, "condition": "Unexpected error" }
  ],
  "validation": {
    "productId": "Must not be null or 'null' string, max length 64",
    "pbiId": "Must not be null or 'null' string, max length 64",
    "newDescription": "Must not be null (empty string is allowed)"
  },
  "testScenarios": [
    "Should return 202 when description changed successfully",
    "Should return 202 when description changed to empty string",
    "Should return 400 when newDescription is null",
    "Should return 400 when productId is invalid",
    "Should return 400 when pbiId is invalid",
    "Should return 404 when PBI not found",
    "Should return 500 when unexpected error occurs"
  ]
}