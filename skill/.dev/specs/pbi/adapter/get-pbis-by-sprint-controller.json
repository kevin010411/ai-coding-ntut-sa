{
  "restController": "GetBacklogItemsBySprintController",
  "spec": {
    "basePath": "v1/api/sprints/{sprintId}/pbis",
    "endpoints": [
      {
        "method": "GET",
        "path": "",
        "useCase": "GetBacklogItemsBySprintUseCase",
        "mapping": {
          "input": {
            "type": "path",
            "pathVars": [
              "sprintId"
            ]
          },
          "output": {
            "type": "list",
            "entity": "readonlyProductBacklogItem",
            "itemType": "readOnlyEntity"
          }
        },
        "responses": {
          "200": {
            "body": "List<readonlyProductBacklogItem>"
          },
          "400": {
            "body": "ApiError"
          },
          "401": {
            "body": "ApiError"
          },
          "500": {
            "body": "ApiError"
          }
        },
        "produces": [
          "application/json"
        ]
      }
    ]
  },
  "contracts": {
    "name": "ApiError",
    "fields": [
      {
        "name": "code",
        "type": "string",
        "example": "SPRINT_NOT_FOUND"
      },
      {
        "name": "message",
        "type": "string"
      },
      {
        "name": "traceId",
        "type": "string"
      }
    ]
  },
  "policies": {
    "validation": [
      {
        "target": "path.sprintId",
        "rules": [
          "notBlank"
        ]
      }
    ],
    "caching": {
      "etag": "optional",
      "cacheControl": "max-age=60, public"
    },
    "observability": {
      "logging": "request-and-error",
      "tracing": true,
      "metrics": true
    }
  },
  "testScenarios": [
    {
      "name": "should_return_200_with_pbi_list_when_sprint_has_pbis",
      "given": "Sprint exists and contains multiple PBIs",
      "when": "GET /v1/api/sprints/{sprintId}/pbis",
      "then": [
        "Returns HTTP 200",
        "Response body contains List<readonlyProductBacklogItem>",
        "Each readonlyProductBacklogItem contains all required fields",
        "PBIs are sorted by orderId",
        "Content-Type is application/json"
      ]
    },
    {
      "name": "should_return_200_with_empty_list_when_sprint_has_no_pbis",
      "given": "Sprint exists but has no PBIs",
      "when": "GET /v1/api/sprints/{sprintId}/pbis",
      "then": [
        "Returns HTTP 200",
        "Response body contains empty list []",
        "Content-Type is application/json"
      ]
    },
    {
      "name": "should_return_200_with_empty_list_when_sprint_not_found",
      "given": "Sprint does not exist",
      "when": "GET /v1/api/sprints/{nonExistentSprintId}/pbis",
      "then": [
        "Returns HTTP 200",
        "Response body contains empty list []",
        "Content-Type is application/json"
      ]
    },
    {
      "name": "should_return_400_when_sprint_id_is_blank",
      "given": "Sprint ID is blank or empty",
      "when": "GET /v1/api/sprints/ /pbis",
      "then": [
        "Returns HTTP 400",
        "Response body contains ApiError",
        "Error code indicates validation failure"
      ]
    },
    {
      "name": "should_return_401_when_unauthorized",
      "given": "Request lacks proper authentication",
      "when": "GET /v1/api/sprints/{sprintId}/pbis without auth token",
      "then": [
        "Returns HTTP 401",
        "Response body contains ApiError",
        "Error code indicates authentication required"
      ]
    },
    {
      "name": "should_include_estimate_when_pbi_has_estimate",
      "given": "Sprint contains PBIs with estimates",
      "when": "GET /v1/api/sprints/{sprintId}/pbis",
      "then": [
        "Returns HTTP 200",
        "PBIs with estimates include EstimateReadOnly",
        "EstimateReadOnly contains points, type, and confidence"
      ]
    }
  ],
  "implementation": {
    "controller": {
      "annotations": [
        "@RestController",
        "@RequestMapping(\"/v1/api/sprints\")",
        "@Tag(name = \"Sprint Product Backlog Items\", description = \"Operations for retrieving PBIs of a Sprint\")"
      ],
      "dependencies": [
        "GetBacklogItemsBySprintUseCase"
      ]
    },
    "method": {
      "annotations": [
        "@GetMapping(\"/{sprintId}/pbis\")",
        "@Operation(summary = \"Get all Product Backlog Items for a Sprint\")",
        "@ApiResponses(value = {...})"
      ],
      "parameters": [
        {
          "name": "sprintId",
          "type": "String",
          "annotation": "@PathVariable",
          "validation": "@NotBlank"
        }
      ],
      "returnType": "ResponseEntity<List<readonlyProductBacklogItem>>"
    }
  },
  "notes": [
    "Returns empty list instead of 404 when Sprint not found (as per use case spec)",
    "PBIs are returned sorted by orderId",
    "All PBI fields are included in the response",
    "Response is cacheable for 60 seconds to reduce database load",
    "Estimate information is included when available"
  ]
}
