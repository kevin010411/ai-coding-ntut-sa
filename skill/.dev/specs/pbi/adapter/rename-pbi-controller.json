{
  "useCase": "RenameProductBacklogItemController",
  "behavior": "Rename a product backlog item",
  "canonicalResourcePath": "/v1/api/pbis/{pbiId}",
  "spec": {
    "basePath": "/v1/api/pbis/{pbiId}/rename",
    "endpoints": [
      {
        "method": "PUT",
        "path": "",
        "summary": "Rename Product Backlog Item",
        "useCase": "RenameProductBacklogItemUseCase",
        "mapping": {
          "input": { 
            "type": "body", 
            "dto": "RenamePbiRequest",
            "pathVars": ["pbiId"]
          },
          "output": { 
            "mode": "async-202", 
            "operationId": true 
          }
        },
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "responses": {
          "202": { 
            "body": "AcceptedResponse", 
            "headers": ["Location", "Operation-Id"] 
          },
          "400": { "body": "ApiError" },
          "404": { "body": "ApiError" },
          "409": { "body": "ApiError" }
        },
        "headers": {
          "request": ["Idempotency-Key"],
          "response": ["Location", "Operation-Id", "traceId"]
        }
      }
    ],
    "errorMapping": [
      { "domain": "PbiNotFound", "http": 404, "code": "PBI_NOT_FOUND" },
      { "domain": "InvalidName", "http": 400, "code": "INVALID_NAME" },
      { "domain": "NameTooLong", "http": 400, "code": "NAME_TOO_LONG" },
      { "domain": "EmptyName", "http": 400, "code": "EMPTY_NAME" }
    ]
  },
  "contracts": {
    "dtos": [
      {
        "name": "RenamePbiRequest",
        "fields": [
          { "name": "productId", "type": "string", "required": true, "minLength": 1, "maxLength": 64, "description": "Product ID that contains the PBI" },
          { "name": "newName", "type": "string", "required": true, "minLength": 1, "maxLength": 255, "description": "New name for the PBI" }
        ]
      },
      {
        "name": "AcceptedResponse",
        "fields": [
          { "name": "operationId", "type": "string" },
          { "name": "status", "type": "string", "default": "ACCEPTED" }
        ]
      },
      {
        "name": "ApiError",
        "fields": [
          { "name": "code", "type": "string" },
          { "name": "message", "type": "string" },
          { "name": "traceId", "type": "string" }
        ]
      }
    ]
  },
  "policies": {
    "validation": [
      { "target": "path.pbiId", "rules": ["notBlank", "length<=64"] },
      { "target": "body.productId", "rules": ["notBlank", "length<=64"] },
      { "target": "body.newName", "rules": ["notBlank", "length<=255"] }
    ],
    "idempotency": { 
      "header": "Idempotency-Key", 
      "ttlSeconds": 600 
    },
    "observability": { 
      "logging": "request-and-error", 
      "tracing": true, 
      "metrics": true 
    },
    "async": { 
      "operationLocationTemplate": "/v1/api/operations/{operationId}" 
    }
  }
}