{
  "useCase": "SetTaskStatusController",
  "behavior": "Set the status of a task",
  "canonicalResourcePath": "/v1/api/pbis/{pbiId}/tasks/{taskId}",
  "spec": {
    "basePath": "/v1/api/pbis/{pbiId}/tasks/{taskId}/status",
    "endpoints": [
      {
        "method": "PUT",
        "path": "",
        "summary": "Set Task Status",
        "useCase": "SetTaskStatusUseCase",
        "mapping": {
          "input": { 
            "type": "body", 
            "dto": "SetTaskStatusRequest",
            "pathVars": ["pbiId", "taskId"]
          },
          "output": { 
            "mode": "async-202", 
            "operationId": true 
          }
        },
        "produces": ["application/json"],
        "consumes": ["application/json"],
        "responses": {
          "202": { 
            "body": "AcceptedResponse", 
            "headers": ["Location", "Operation-Id"] 
          },
          "400": { "body": "ApiError" },
          "404": { "body": "ApiError" }
        },
        "headers": {
          "request": ["Idempotency-Key"],
          "response": ["Location", "Operation-Id", "traceId"]
        }
      }
    ],
    "errorMapping": [
      { "domain": "TaskNotFound", "http": 404, "code": "TASK_NOT_FOUND" },
      { "domain": "PbiNotFound", "http": 404, "code": "PBI_NOT_FOUND" },
      { "domain": "InvalidTaskState", "http": 400, "code": "INVALID_TASK_STATE" }
    ]
  },
  "contracts": {
    "dtos": [
      {
        "name": "SetTaskStatusRequest",
        "fields": [
          { "name": "productId", "type": "string", "required": true, "minLength": 1, "maxLength": 64, "description": "Product ID that contains the PBI" },
          { "name": "taskState", "type": "string", "required": true, "enum": ["TODO", "DOING", "TESTING", "REVIEW", "DONE"], "description": "New status for the task" }
        ]
      },
      {
        "name": "AcceptedResponse",
        "fields": [
          { "name": "operationId", "type": "string" },
          { "name": "status", "type": "string", "default": "ACCEPTED" }
        ]
      },
      {
        "name": "ApiError",
        "fields": [
          { "name": "code", "type": "string" },
          { "name": "message", "type": "string" },
          { "name": "traceId", "type": "string" }
        ]
      }
    ]
  },
  "policies": {
    "validation": [
      { "target": "path.pbiId", "rules": ["notBlank", "length<=64"] },
      { "target": "path.taskId", "rules": ["notBlank", "length<=64"] },
      { "target": "body.productId", "rules": ["notBlank", "length<=64"] },
      { "target": "body.taskState", "rules": ["notBlank", "in:TODO,DOING,TEST,REVIEW,DONE"] }
    ],
    "idempotency": { 
      "header": "Idempotency-Key", 
      "ttlSeconds": 600 
    },
    "observability": { 
      "logging": "request-and-error", 
      "tracing": true, 
      "metrics": true 
    },
    "async": { 
      "operationLocationTemplate": "/v1/api/operations/{operationId}" 
    }
  },
  "testScenarios": [
    {
      "name": "should_set_task_status_successfully",
      "given": "Task 存在且處於 TODO 狀態",
      "when": "PUT /v1/api/pbis/{pbiId}/tasks/{taskId}/status with DOING state",
      "then": [
        "應該回傳 HTTP 202 Accepted",
        "Response 應包含 operationId",
        "Task 狀態應變更為 DOING"
      ]
    },
    {
      "name": "should_allow_status_transition_backwards",
      "given": "Task 處於 TEST 狀態",
      "when": "PUT /v1/api/pbis/{pbiId}/tasks/{taskId}/status with DOING state",
      "then": [
        "應該回傳 HTTP 202 Accepted",
        "Task 狀態應變更為 DOING",
        "註：系統允許狀態回退"
      ]
    },
    {
      "name": "should_return_404_when_task_not_found",
      "given": "Task 不存在",
      "when": "PUT /v1/api/pbis/{pbiId}/tasks/{taskId}/status",
      "then": [
        "應該回傳 HTTP 404",
        "Response body 應包含 TASK_NOT_FOUND 錯誤碼"
      ]
    },
    {
      "name": "should_return_400_when_invalid_task_state",
      "given": "請求包含無效的狀態值",
      "when": "PUT /v1/api/pbis/{pbiId}/tasks/{taskId}/status with 'INVALID' state",
      "then": [
        "應該回傳 HTTP 400",
        "Response body 應包含 INVALID_TASK_STATE 錯誤碼"
      ]
    },
    {
      "name": "should_be_idempotent_with_same_key",
      "given": "Task 狀態已經被改為 DOING",
      "when": "重複發送相同的請求（相同 Idempotency-Key）",
      "then": [
        "應該回傳相同的 operationId",
        "不應該重複執行狀態變更"
      ]
    }
  ]
}