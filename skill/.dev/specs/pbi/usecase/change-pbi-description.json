{
  "useCase": "ChangeProductBacklogItemDescription",
  "behavior": "Change the description of a Product Backlog Item",
  "input": [
    { "name": "productId", "type": "String", "note": "Product 的唯一識別碼" },
    { "name": "pbiId", "type": "String", "note": "PBI 的唯一識別碼" },
    { "name": "newDescription", "type": "String", "note": "新的描述內容，可為空字串" }
  ],
  "aggregate": "ProductBacklogItem",
  "aggregateId": "PbiId",
  "method": "ProductBacklogItem.changeDescription(Description newDescription)",
  "domainEvent": ["ProductBacklogItemEvents.PbiDescriptionChanged"],
  "repository": "ProductBacklogItemRepository",
  "output": "CqrsOutput with pbiId",
  "domainModelNotes": [
    "requireNotNull(\"New description is not null\", ()-> newDescription)",
    "ensure(\"Description is changed\", () -> description.equals(newDescription));"
  ],
  "domainEvents": [
    {
      "name": "ProductBacklogItemEvents.PbiDescriptionChanged",
      "description": "PBI 描述已變更",
      "attributes": [
        { "name": "productId", "type": "ProductId",  "constraint": "non-null" },
        { "name": "pbiId", "type": "PbiId",  "constraint": "non-null" },
        { "name": "oldDescription", "type": "Description",  "constraint": "non-null" },
        { "name": "newDescription", "type": "Description",  "constraint": "non-null" }
      ]
    }
  ]
}