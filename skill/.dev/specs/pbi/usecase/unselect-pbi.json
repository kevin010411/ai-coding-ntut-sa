{
  "useCase": "UnselectProductBacklogItem",
  "behavior": "Unselect a PBI from a sprint",
  "input": [
    { "name": "productId", "type": "String"},
    { "name": "sprintId", "type": "String"},
    { "name": "pbiId", "type": "String"},
    { "name": "userId", "type": "String", "note": "只在 domain event 中紀錄執行這個使用案例的人" }
  ],
  "aggregate": "ProductBacklogItem",
  "aggregateId": "PbiId",
  "method": "ProductBacklogItem.unselect",
  "domainEvent": "ProductBacklogItemEvents.PbiUnselected",
  "repository": "ProductBacklogItemRepository",
  "output": "CqrsOutput with pbiId",
  "domainModelNotes": [
    "require(\"PBI is selected\", ()-> this.sprintId == null)",
    "this.sprintId = null;",
    "this.state = PbiState.BACKLOGGED;"
  ],
  "domainEvents": [
    {
      "name": "ProductBacklogItemEvents.PbiUnselected",
      "description": "PBI 已從 Sprint 移除",
      "attributes": [
        { "name": "productId", "type": "ProductId",  "constraint": "non-null" },
        { "name": "sprintId", "type": "SprintId",  "constraint": "non-null" },
        { "name": "pbiId", "type": "PbiId",  "constraint": "non-null" },
        { "name": "state", "type": "PbiState", "constraint": "non-null" },
        { "name": "userId", "type": "String", "constraint": "non-null"}
      ]
    }
  ]
}