{
  "useCase": "MoveTask",
  "behavior": "Move a task to a different state on the Scrum Board",
  "input": [
    { "name": "productId", "type": "String", "note": "Product 的唯一識別碼" },
    { "name": "sprintId", "type": "String", "note": "Sprint 的唯一識別碼" },
    { "name": "pbiId", "type": "String", "note": "PBI 的唯一識別碼" },
    { "name": "taskId", "type": "String", "note": "Task 的唯一識別碼" },
    { "name": "newState", "type": "String", "note": "新的任務狀態 (TODO, DOING, TESTING, REVIEW, DONE)" }
  ],
  "aggregate": "ProductBacklogItem",
  "aggregateId": "PbiId",
  "method": "ProductBacklogItem.moveTask(TaskId taskId, ScrumBoardTaskState newState)",
  "domainEvent": ["ProductBacklogItemEvents.TaskMoved", "ProductBacklogItemEvents.PbiCompleted", "ProductBacklogItemEvents.PbiWorkRegressed"],
  "repository": "ProductBacklogItemRepository",
  "output": "CqrsOutput with taskId",
  "domainModelNotes": [
    "requireNotNull(\"Task ID is not null\", ()-> taskId)",
    "requireNotNull(\"New state is not null\", ()-> newState)",
    "require(\"Task exists\", ()-> tasks.stream().anyMatch(t -> t.taskId.equals(taskId)))",
    "require(\"New state is different from current state\", ()-> !task.state.equals(newState))",
    "ensure(\"Task state is updated\", () -> task.state.equals(newState))",
    "當所有 tasks 都移到 DONE 時，PBI 狀態應從 IN_PROGRESS 變成 DONE",
    "當 PBI 在 DONE 狀態，有 task 從 DONE 移到其他狀態時，PBI 應從 DONE 退回 IN_PROGRESS"
  ],
  "domainEvents": [
    {
      "name": "ProductBacklogItemEvents.TaskMoved",
      "description": "Task 移動到新的狀態",
      "attributes": [
        { "name": "productId", "type": "ProductId", "constraint": "non-null" },
        { "name": "sprintId", "type": "SprintId", "constraint": "non-null" },
        { "name": "pbiId", "type": "PbiId", "constraint": "non-null" },
        { "name": "taskId", "type": "TaskId", "constraint": "non-null" },
        { "name": "fromState", "type": "ScrumBoardTaskState", "constraint": "non-null" },
        { "name": "toState", "type": "ScrumBoardTaskState", "constraint": "non-null" },
        { "name": "movedBy", "type": "String", "constraint": "non-null" },
        { "name": "occurredAt", "type": "Instant", "constraint": "non-null" }
      ]
    },
    {
      "name": "ProductBacklogItemEvents.PbiCompleted",
      "description": "PBI 完成（當所有 tasks 都移到 DONE 時觸發）",
      "attributes": [
        { "name": "productId", "type": "ProductId", "constraint": "non-null" },
        { "name": "sprintId", "type": "SprintId", "constraint": "nullable" },
        { "name": "pbiId", "type": "PbiId", "constraint": "non-null" },
        { "name": "previousState", "type": "PbiState", "constraint": "non-null" },
        { "name": "newState", "type": "PbiState", "constraint": "non-null" },
        { "name": "completedBy", "type": "String", "constraint": "non-null" }
      ],
      "condition": "當移動 task 到 DONE 後，如果 PBI 處於 IN_PROGRESS 狀態且所有 tasks 都是 DONE"
    },
    {
      "name": "ProductBacklogItemEvents.PbiWorkRegressed",
      "description": "PBI 工作退回（當 task 從 DONE 移到其他狀態時觸發）",
      "attributes": [
        { "name": "productId", "type": "ProductId", "constraint": "non-null" },
        { "name": "sprintId", "type": "SprintId", "constraint": "nullable" },
        { "name": "pbiId", "type": "PbiId", "constraint": "non-null" },
        { "name": "previousState", "type": "PbiState", "constraint": "non-null" },
        { "name": "newState", "type": "PbiState", "constraint": "non-null" },
        { "name": "reason", "type": "String", "constraint": "nullable" }
      ],
      "condition": "當 PBI 處於 DONE 狀態，有 task 從 DONE 移到其他狀態時"
    }
  ]
}