{
  "useCase": "CreateProductBacklogItem",
  "behavior": "Create a new product backlog item",
  "input": [
    { "name": "productId", "type": "String", "note": "Product 的唯一識別碼" },
    { "name": "pbiId", "type": "String", "note": "PBI 的唯一識別碼" },
    { "name": "name", "type": "String", "note": "PBI 的顯示名稱" },
    { "name": "description", "type": "String", "note": "PBI 詳細內容" },
    { "name": "sprintId", "type": "String", "note": "null 代表尚未選入任何 sprint" },
    { "name": "estimateValue", "type": "String", "note": "估算值，null 代表未估算" },
    { "name": "estimateType", "type": "String", "note": "估算類型 (STORY_POINT, T_SHIRT_SIZE 等)，null 時預設為 STORY_POINT" },
    { "name": "importance", "type": "String", "note": "重要性，一定要指定，可與其他 PBI 重複" },
    { "name": "pbiState", "type": "String", "note": "{BACKLOGGED or SELECTED}}" },
    { "name": "creatorId", "type": "String", "note": "建立 Product 的使用者 ID, 紀錄在領域事件中" },
    { "name": "acceptanceCriteria", "type": "List<AcceptanceCriterionInput>", "note": "驗收條件清單，null 代表尚未定義" }
  ],
  "aggregate": "ProductBacklogItem",
  "aggregateId": "PbiId",
  "method": "ProductBacklogItem constructor",
  "domainEvent": "ProductBacklogItemEvents.PbiCreated",
  "repository": "ProductBacklogItemRepository",
  "output": "CqrsOutput with pbiId",
  "domainModelNotes": [
    "ProductBacklogItem 使用建構函數建立新實例"
  ],
  "constructorPreconditions": [
    {
      "rule": "Required fields validation",
      "description": "所有標記為 non-null 的欄位都必須通過 requireNotNull() 檢查",
      "fields": ["productId", "pbiId", "name", "importance", "pbiState", "orderId", "creatorId"]
    },
    {
      "rule": "State consistency validation", 
      "description": "當 sprintId 為 null 時，pbiState 必須是 BACKLOGGED",
      "validation": "if (sprintId == null) { require('When sprintId is null, state must be BACKLOGGED', () -> pbiState == PbiState.BACKLOGGED); }"
    }
  ],
  "constructorPostconditions": [
    {
      "rule": "Field assignment verification",
      "description": "使用 ensure() 檢查所有欄位都正確設定",
      "checks": [
        "PBI id is set correctly",
        "PBI product id is set correctly", 
        "PBI name is set correctly",
        "PBI description is set correctly (nullable)",
        "PBI state is set correctly",
        "PBI sprint id is set correctly (nullable)",
        "PBI importance is set correctly",
        "PBI estimate is set correctly (nullable)",
        "PBI creator id is set correctly"
      ]
    },
    {
      "rule": "Domain event verification",
      "description": "確保 PbiCreated 領域事件正確產生",
      "validation": "最後一個領域事件必須是 PbiCreated 且包含所有正確欄位值"
    }
  ],
  "aggregates": [
    {
      "name": "ProductBacklogItem",
      "description": "產品待辦事項",
      "attributes": [
        { "name": "productId", "type": "ProductId",  "constraint": "non-null" },
        { "name": "id", "type": "PbiId",  "constraint": "non-null" },
        { "name": "name", "type": "String","constraint": "non-null" },
        { "name": "description", "type": "String",  "constraint": "nullable" },
        { "name": "sprintId", "type": "SprintId",  "constraint": "nullable" },
        { "name": "tagRefs", "type": "final SequencedSet<TagRef>",  "constraint": "final tagRefs = new LinkedHashSet()" },
        { "name": "estimate", "type": "Estimate",  "constraint": "nullable" },
        { "name": "importance", "type": "Importance",  "constraint": "non-null" },
        { "name": "state", "type": "PbiState", "constraint": "if SprintId == null, state = PbiState.BACKLOGGED, else state = PbiState.SELECTED" },
        { "name": "acceptances", "type": "final SequencedSet<AcceptanceCriterion>", "constraint": "acceptances = new LinkedHashSet()" },
        { "name": "tasks", "type": "final SequencedSet<Task>", "constraint": "tasks = new LinkedHashSet()" },
        { "name": "note", "type": "String", "constraint": "nullable" },
        { "name": "creatorId", "type": "String", "constraint": "non-null"},
        { "name": "extension", "type": "String", "constraint": "nullable" }
      ]
    },
    {
      "name": "TagGroup",
      "description": "Tag 分組，例如 PBI 類型分組（Tag: Story, Bug, Spike）或 PBI 重要性分組（Tag: Must Have, Nice to Have, Optional）",
      "attributes": [
        { "name": "productId", "type": "ProductId",  "constraint": "non-null" },
        { "name": "id", "type": "TagGroupId",  "constraint": "non-null" },
        { "name": "name", "type": "String","constraint": "non-null" },
        { "name": "description", "type": "String",  "constraint": "nullable" },
        { "name": "tags", "type": "final SequencedSet<Tag>",  "constraint": "final tags = new LinkedHashSet()" },
        { "name": "note", "type": "String", "constraint": "nullable" },
        { "name": "creatorId", "type": "String", "constraint": "non-null"},
        { "name": "extension", "type": "String", "constraint": "nullable" }
      ]
    }
  ],
  "domainEvents": [
    {
      "name": "ProductBacklogItemEvents.PbiCreated",
      "description": "PBI已建立",
      "attributes": [
        { "name": "productId", "type": "ProductId",  "constraint": "non-null" },
        { "name": "id", "type": "PbiId",  "constraint": "non-null" },
        { "name": "name", "type": "String","constraint": "non-null" },
        { "name": "description", "type": "String",  "constraint": "nullable" },
        { "name": "sprintId", "type": "SprintId",  "constraint": "nullable" },
        { "name": "tagRefs", "type": "SequencedSet<TagRef>",  "constraint": "non-null" },
        { "name": "estimate", "type": "Estimate",  "constraint": "nullable" },
        { "name": "importance", "type": "Importance",  "constraint": "non-null" },
        { "name": "state", "type": "PbiState", "constraint": "non-null" },
        { "name": "acceptances", "type": "SequencedSet<AcceptanceCriterion>", "constraint": "non-null" },
        { "name": "tasks", "type": "SequencedSet<Task>", "constraint": "non-null" },
        { "name": "note", "type": "String", "constraint": "nullable" },
        { "name": "extension", "type": "String", "constraint": "nullable" },
        { "name": "creatorId", "type": "String", "constraint": "non-null"}
      ]
    }
  ],
  "entities": [
    {
      "name": "Task",
      "description": "從 PBI 切割的工作項目",
      "attributes": [
        { "name": "pbiId", "type": "PbiId" },
        { "name": "id", "type": "TaskId" },
        { "name": "name", "type": "String" },
        { "name": "state", "type": "TaskState" },
        { "name": "assigneeIds", "type": "final Set<String>" },
        { "name": "estimateHours", "type": "EstimatedHours" },
        { "name": "remainingHours", "type": "RemainingHours" },
        { "name": "blockedBy", "type": "final SequencedSet<TaskId>","constraint": "blockedBy = new LinkedHashSet()" },
        { "name": "note", "type": "String", "constraint": "nullable" },
        { "name": "extension", "type": "String", "constraint": "nullable" }
      ]
    },
    {
      "name": "Tag",
      "description": "分類 PBI 的標籤",
      "attributes": [
        { "name": "id", "type": "TagId" },
        { "name": "name", "type": "String" },
        { "name": "description", "type": "String" },
        { "name": "color", "type": "String" }
      ]
    }
  ],
  "valueObjects": [
    {
      "name": "TagRef",
      "description": "紀錄 PBI 貼上哪個 TagGroup 的 Tag Gaol",
      "fields": [
        { "name": "tagGroupId", "type": "TagGroupId" },
        { "name": "tagId", "type": "TagId" }
      ]
    },
    {
      "name": "Estimate",
      "description": "PBI 估算",
      "fields": [
        { "name": "type", "type": "EstimateType" },
        { "name": "value", "type": "String" }
      ]
    },
    {
      "name": "Importance",
      "description": "PBI 重要性",
      "fields": [
        { "name": "value", "type": "long" }
      ]
    },
    {
      "name": "AcceptanceCriterion",
      "description": "描述單一 PBI 的驗收條件",
      "fields": [
        { "name": "value", "type": "String" },
        { "name": "isMandatory", "type": "boolean" },
        { "name": "isMet", "type": "boolean" },
        { "name": "note", "type": "String" }
      ]
    },
    {
      "name": "EstimatedHours",
      "description": "Task 預估工時",
      "fields": [
        { "name": "value", "type": "Hours" }
      ]
    },
    {
      "name": "RemainingHours",
      "description": "Task 剩餘工時",
      "fields": [
        { "name": "value", "type": "Hours" }
      ]
    }
  ],
  "enums": [
    {
      "name": "EstimateType",
      "description": "PBI 估算方法",
      "values": ["STORY_POINT","T_SHIRT_SIZE", "IDEAL_DAY","USER_DEFINED","NONE"]
    },
    {
      "name": "PbiState",
      "description": "PBI 狀態",
      "values": [
        {"name": "BACKLOGGED",  "note" : "在產品待辦清單中，尚未定義驗收條件"},
        {"name": "READY",  "note" : "已定義驗收條件"},
        {"name": "SELECTED",  "note" : "已選到某個 Sprint"},
        {"name": "IN_PROGRESS",  "note" : "已經在 Sprint 中開始開發"},
        {"name": "DONE",  "note" : "已完成並符合 DoD"},
        {"name": "ACCEPTED",  "note" : "已被 PO 接受"},
        {"name": "REJECTED",  "note" : "已被 PO 拒絕"},
        {"name": "DEPLOYED",  "note" : "已被部署"},
        {"name": "FEEDBACKED",  "note" : "已收到使用者回饋"},
        {"name": "CANCELED",  "note" : "已取消，不再實作，隨時都可取消"}
      ]
    }
  ]
}