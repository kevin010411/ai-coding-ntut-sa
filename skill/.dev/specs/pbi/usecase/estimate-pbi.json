{
  "useCase": "EstimateProductBacklogItem",
  "behavior": "Estimate a PBI",
  "input": [
    { "name": "productId", "type": "String", "note": "Product 的唯一識別碼" },
    { "name": "pbiId", "type": "String", "note": "PBI 的唯一識別碼" },
    { "name": "estimateType", "type": "String", "note": "STORY_POINT, T_SHIRT_SIZE, IDEAL_DAY, USER_DEFINED, NONE" },
    { "name": "estimateValue", "type": "String", "note": "non-null" }
  ],
  "aggregate": "ProductBacklogItem",
  "aggregateId": "PbiId",
  "method": "ProductBacklogItem.estimatePbi(Estimate estimate)",
  "domainEvent": ["ProductBacklogItemEvents.PbiEstimated"],
  "repository": "ProductBacklogItemRepository",
  "output": "CqrsOutput with taskId",
  "domainModelNotes": [
    "reject(\"New, estimate == old estimate\", () -> this.estimate == estimate);"
  ],
  "domainEvents": [
    {
      "name": "ProductBacklogItemEvents.PbiEstimated",
      "description": "PBI 已估算",
      "attributes": [
        { "name": "productId", "type": "ProductId",  "constraint": "non-null" },
        { "name": "pbiId", "type": "PbiId",  "constraint": "non-null" },
        { "name": "estimate", "type": "Estimate",  "constraint": "non-null" }
      ]
    }
  ]
}
