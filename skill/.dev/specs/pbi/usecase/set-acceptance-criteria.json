{
  "useCase": "SetAcceptanceCriteria",
  "behavior": "Set acceptance criteria for a product backlog item",
  "input": [
    { "name": "productId", "type": "String", "note": "Product 的唯一識別碼" },
    { "name": "pbiId", "type": "String", "note": "PBI 的唯一識別碼" },
    { "name": "acceptances", "type": "List<String>", "note": "Acceptance criteria 列表" }
  ],
  "aggregate": "ProductBacklogItem",
  "aggregateId": "PbiId",
  "method": "ProductBacklogItem.setAcceptanceCriteria(List<String> acceptances)",
  "domainEvent": ["ProductBacklogItemEvents.AcceptanceCriteriaSet"],
  "repository": "ProductBacklogItemRepository",
  "output": "CqrsOutput with pbiId",
  "domainModelNotes": [
    "requireNotNull(\"Acceptances is not null\", ()-> acceptances)",
    "ensure(\"Acceptance criteria are set\", () -> this.acceptances.equals(acceptances))"
  ],
  "domainEvents": [
    {
      "name": "ProductBacklogItemEvents.AcceptanceCriteriaSet",
      "description": "PBI 的 Acceptance Criteria 已設定",
      "attributes": [
        { "name": "productId", "type": "ProductId",  "constraint": "non-null" },
        { "name": "pbiId", "type": "PbiId",  "constraint": "non-null" },
        { "name": "acceptances", "type": "List<String>",  "constraint": "non-null" }
      ]
    }
  ]
}