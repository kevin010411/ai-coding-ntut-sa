{
  "useCase": "RenameProductBacklogItem",
  "behavior": "Rename a product backlog item",
  "input": [
    { "name": "productId", "type": "String", "note": "Product 的唯一識別碼" },
    { "name": "pbiId", "type": "String", "note": "PBI 的唯一識別碼" },
    { "name": "newName", "type": "String", "note": "新的 PBI 名稱，non-null, non-empty" }
  ],
  "aggregate": "ProductBacklogItem",
  "aggregateId": "PbiId",
  "method": "ProductBacklogItem.rename(String newName)",
  "domainEvent": ["ProductBacklogItemEvents.PbiRenamed"],
  "repository": "ProductBacklogItemRepository",
  "output": "CqrsOutput with pbiId",
  "domainModelNotes": [
    "requireNotNull(\"New name is not null\", ()-> newName)",
    "require(\"New name is not empty\", ()-> !newName.trim().isEmpty())",
    "require(\"New name is different from current name\", ()-> !this.name.equals(newName))",
    "ensure(\"Name is updated\", () -> this.name.equals(newName))"
  ],
  "domainEvents": [
    {
      "name": "ProductBacklogItemEvents.PbiRenamed",
      "description": "PBI 被重新命名",
      "attributes": [
        { "name": "productId", "type": "ProductId",  "constraint": "non-null" },
        { "name": "pbiId", "type": "PbiId",  "constraint": "non-null" },
        { "name": "oldName", "type": "String",  "constraint": "non-null" },
        { "name": "newName", "type": "String",  "constraint": "non-null" }
      ]
    }
  ]
}