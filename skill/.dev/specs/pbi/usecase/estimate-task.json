{
  "useCase": "EstimateTask",
  "behavior": "The first time to estimate a task",
  "input": [
    { "name": "productId", "type": "String", "note": "Product 的唯一識別碼" },
    { "name": "pbiId", "type": "String", "note": "PBI 的唯一識別碼" },
    { "name": "taskId", "type": "String", "note": "Task 的唯一識別碼" },
    { "name": "estimatedHours", "type": "String", "note": "non-null, 支援小數如 '0.5', '1.5', 內部使用 BigDecimal" }
  ],
  "aggregate": "ProductBacklogItem",
  "aggregateId": "PbiId",
  "method": "ProductBacklogItem.estimateTask(TaskId taskId, EstimatedHours estimatedHours)",
  "domainEvent": ["ProductBacklogItemEvents.TaskEstimated"],
  "repository": "ProductBacklogItemRepository",
  "output": "CqrsOutput with taskId",
  "domainModelNotes": [
    "requireNotNull(\"Task ID is not null\", ()-> taskId)",
    "requireNotNull(\"Estimated Hours is not null\", ()-> estimatedHours)",
    "require(\"Task is not estimated\", ()-> task.estimatedHours == null)",
    "ensure(\"Estimated hours are set\", () -> task.estimatedHours.equals(estimatedHours));",
    "ensure(\"Remaining hours are set\", () -> task.remainingHours.equals(estimatedHours));"
  ],
  "domainEvents": [
    {
      "name": "ProductBacklogItemEvents.TaskEstimated",
      "description": "Task 第一次估算",
      "attributes": [
        { "name": "productId", "type": "ProductId",  "constraint": "non-null" },
        { "name": "pbiId", "type": "PbiId",  "constraint": "non-null" },
        { "name": "taskId", "type": "TaskId",  "constraint": "non-null" },
        { "name": "estimatedHours", "type": "EstimatedHours",  "constraint": "non-null" },
        { "name": "remainingHours", "type": "RemainingHours",  "constraint": "non-null" }
      ]
    }
  ]
}
