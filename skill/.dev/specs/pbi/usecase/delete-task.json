{
  "useCase": "DeleteTask",
  "behavior": "Delete a new task",
  "input": [
    { "name": "productId", "type": "String", "note": "Product 的唯一識別碼" },
    { "name": "pbiId", "type": "String", "note": "PBI 的唯一識別碼" },
    { "name": "taskId", "type": "String", "note": "Task 的唯一識別碼" },
    { "name": "reason", "type": "String", "note": "刪除理由, 只紀錄在領域事件中" },
    { "name": "userId", "type": "String", "note": "刪除 Task 的使用者 ID, 只紀錄在領域事件中" }
  ],
  "aggregate": "ProductBacklogItem",
  "aggregateId": "PbiId",
  "method": "ProductBacklogItem.deleteTask(TaskId taskId, String reason, String userId)",
  "domainEvent": "ProductBacklogItemEvents.TaskDeleted",
  "repository": "ProductBacklogItemRepository",
  "output": "CqrsOutput with taskId",
  "domainModelNotes": [
    "requireNotNull(\"task ID is not null\", ()-> taskId)",
    "requireNotNull(\"userId ID is not null\", ()-> userId)",
    "刪除 task 後，如果剩餘的所有 tasks 都是 DONE，則 PBI 狀態應變成 DONE",
    "如果 PBI 狀態從 IN_PROGRESS 變成 DONE，應產生 PbiCompleted 事件"
  ],
  "domainEvents": [
    {
      "name": "ProductBacklogItemEvents.TaskDeleted",
      "description": "Task 已刪除",
      "attributes": [
        { "name": "productId", "type": "ProductId",  "constraint": "non-null" },
        { "name": "pbiId", "type": "PbiId",  "constraint": "non-null" },
        { "name": "taskId", "type": "TaskId",  "constraint": "non-null" },
        { "name": "reason", "type": "String","constraint": "nullable" },
        { "name": "userId", "type": "String", "constraint": "non-null"}
      ]
    },
    {
      "name": "ProductBacklogItemEvents.PbiCompleted",
      "description": "PBI 完成（當刪除 task 後所有剩餘 tasks 都是 DONE 時觸發）",
      "attributes": [
        { "name": "productId", "type": "ProductId", "constraint": "non-null" },
        { "name": "sprintId", "type": "SprintId", "constraint": "nullable" },
        { "name": "pbiId", "type": "PbiId", "constraint": "non-null" },
        { "name": "previousState", "type": "PbiState", "constraint": "non-null" },
        { "name": "newState", "type": "PbiState", "constraint": "non-null" },
        { "name": "completedBy", "type": "String", "constraint": "non-null" }
      ],
      "condition": "當刪除 task 後，如果 PBI 處於 IN_PROGRESS 狀態且所有剩餘的 tasks 都是 DONE（或沒有 tasks）"
    }
  ]
}